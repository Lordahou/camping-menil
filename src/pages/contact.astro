---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import CTABanner from '../components/CTABanner.astro';
import content from '../data/content.json';
import { url } from '../utils/paths';
---

<BaseLayout
  title="Réserver / Nous contacter — Camping du Bac de Ménil"
  description="Réservez votre séjour au Camping du Bac de Ménil ou contactez-nous. Réservation en ligne, par téléphone au 02 43 70 24 54 ou par email."
>
  <Hero
    title="Réserver / Nous contacter"
    subtitle="Réservez votre séjour ou envoyez-nous un message"
    image="/images/galerie/galerie-7.jpg"
    imageAlt="Contact et réservation au Camping du Bac"
    size="medium"
  />

  <!-- RÉSERVATION EN LIGNE -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12 reveal">
        <span class="badge mb-4">Réservation en ligne</span>
        <h2 class="text-forest mb-4">Réservez directement en ligne</h2>
        <p class="text-gray-600 text-lg leading-relaxed mb-8">
          La façon la plus simple et rapide de réserver votre séjour au Camping du Bac.
          Choisissez vos dates, votre hébergement et confirmez votre réservation en quelques clics.
        </p>
        <a
          href={content.site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-lg"
        >
          Réserver en ligne
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <p class="text-gray-400 text-xs mt-3">Redirection vers notre plateforme de réservation sécurisée Naxiresa</p>
      </div>
    </div>
  </section>

  <!-- FORMULAIRE + INFO CONTACT -->
  <section class="py-16 lg:py-24 bg-cream-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
        <!-- Formulaire -->
        <div class="lg:col-span-3 reveal">
          <ContactForm />
        </div>

        <!-- Panel contact -->
        <div class="lg:col-span-2 reveal reveal-delay-2">
          <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-lg sticky top-8">
            <h3 class="text-forest text-xl mb-6">Coordonnées</h3>

            <div class="space-y-5">
              <!-- Téléphone -->
              <a href={`tel:${content.contact.phone.replace(/\s/g, '')}`} class="flex items-start gap-4 group">
                <div class="w-10 h-10 rounded-lg bg-moss flex items-center justify-center flex-shrink-0 group-hover:bg-sage transition-colors">
                  <svg class="w-5 h-5 text-forest" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400 uppercase tracking-wider mb-0.5">Téléphone</p>
                  <p class="text-forest font-semibold text-sm group-hover:text-green transition-colors">{content.contact.phone}</p>
                </div>
              </a>

              <!-- Email -->
              <a href={`mailto:${content.contact.email}`} class="flex items-start gap-4 group">
                <div class="w-10 h-10 rounded-lg bg-moss flex items-center justify-center flex-shrink-0 group-hover:bg-sage transition-colors">
                  <svg class="w-5 h-5 text-forest" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400 uppercase tracking-wider mb-0.5">Email</p>
                  <p class="text-forest font-semibold text-sm group-hover:text-green transition-colors">{content.contact.email}</p>
                </div>
              </a>

              <!-- Adresse -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-moss flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-forest" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400 uppercase tracking-wider mb-0.5">Adresse</p>
                  <p class="text-forest font-semibold text-sm">{content.contact.address}</p>
                  <p class="text-gray-500 text-sm">{content.contact.postalCode} {content.contact.city}</p>
                </div>
              </div>
            </div>

            <!-- Separator -->
            <hr class="my-6 border-gray-100" />

            <!-- Dates d'ouverture -->
            <h4 class="text-forest text-sm font-semibold mb-3">Dates d'ouverture</h4>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Emplacements</span>
                <span class="text-forest font-medium">{content.openingDates.emplacements.start} — {content.openingDates.emplacements.end}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Chalets</span>
                <span class="text-forest font-medium">{content.openingDates.chalets}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Maison éclusière</span>
                <span class="text-forest font-medium">{content.openingDates.maisonEclusiere}</span>
              </div>
            </div>

            <!-- Separator -->
            <hr class="my-6 border-gray-100" />

            <!-- Google Maps -->
            <a
              href={content.contact.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline btn-sm w-full text-center"
            >
              Voir sur Google Maps
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CARTE GOOGLE MAPS -->
  <section class="bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100 reveal">
        <div class="bg-gray-200 aspect-[21/9] flex items-center justify-center relative">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2681.3656936295642!2d-0.676798523292737!3d47.774356576377784!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x480859795f7a0a9b%3A0x8b5667d9dd46ee68!2sCamping%20Municipal%20du%20Bac!5e0!3m2!1sfr!2sfr!4v1773485798029!5m2!1sfr!2sfr"
            width="100%"
            height="100%"
            style="border:0; position:absolute; inset:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localisation du Camping du Bac de Ménil"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- AVIS GOOGLE -->
  <section class="py-16 lg:py-24 bg-cream-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="badge mb-4">Avis clients</span>
        <h2 class="text-forest mb-4">Ce que disent nos visiteurs sur Google</h2>
        <div class="flex items-center justify-center gap-3 mb-2">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></svg>
            ))}
          </div>
          <span class="text-forest font-heading text-2xl" id="google-rating">4.6/5</span>
        </div>
        <p class="text-gray-500 text-sm" id="google-review-count">Avis Google Maps</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8" id="google-reviews">
        {[
          {
            author: "Christelle M.",
            rating: 5,
            date: "Août 2025",
            text: "Super petit camping familial au bord de la Mayenne. Cadre magnifique, reposant et convivial. Services impeccables et équipe accueillante et professionnelle. On reviendra !",
            source: "Google"
          },
          {
            author: "Philippe D.",
            rating: 5,
            date: "Juillet 2025",
            text: "Camping d'une trentaine d'emplacements près d'une guinguette. Les sanitaires sont propres, les gérants très agréables et réactifs. Calme et nature au rendez-vous.",
            source: "Google"
          },
          {
            author: "Laurent B.",
            rating: 5,
            date: "Juin 2025",
            text: "Étape parfaite sur la Vélo Francette. Accueil chaleureux, emplacement au bord de la rivière. Le bac à traction manuelle est une expérience unique à ne pas rater !",
            source: "Google"
          },
          {
            author: "Sandrine V.",
            rating: 5,
            date: "Août 2025",
            text: "Vacances en famille au top. Les enfants ont adoré les pédalos et le canoë. Chalets confortables et bien équipés. Le cadre au bord de la Mayenne est magnifique.",
            source: "Google"
          },
          {
            author: "Marc T.",
            rating: 4,
            date: "Septembre 2025",
            text: "Très bel endroit, calme et verdoyant. Idéal pour se ressourcer. Emplacements spacieux et ombragés. Petit bémol : peu de réseau mobile, mais le Wi-Fi gratuit compense.",
            source: "Google"
          },
          {
            author: "Anne-Sophie R.",
            rating: 5,
            date: "Juillet 2025",
            text: "Un vrai petit paradis ! Nous avons séjourné dans la maison éclusière, un gîte de caractère avec jardin privatif. Les animations estivales (fête du pain, soirée cochon grillé) sont géniales.",
            source: "Google"
          }
        ].map((review, i) => (
          <div class={`bg-white rounded-2xl p-6 lg:p-8 border border-gray-100 shadow-sm hover:shadow-md transition-shadow duration-300 reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="flex items-center justify-between mb-4">
              <div class="flex gap-0.5">
                {Array.from({length: review.rating}).map(() => (
                  <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></svg>
                ))}
                {Array.from({length: 5 - review.rating}).map(() => (
                  <svg class="w-4 h-4 text-gray-200" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></svg>
                ))}
              </div>
              <span class="text-xs text-gray-400">{review.date}</span>
            </div>
            <blockquote class="text-gray-600 text-sm leading-relaxed mb-5 italic">
              "{review.text}"
            </blockquote>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-sage/20 flex items-center justify-center text-green font-semibold text-sm">
                  {review.author.charAt(0)}
                </div>
                <span class="text-forest font-medium text-sm">{review.author}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4" viewBox="0 0 24 24">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span class="text-xs text-gray-400">Google</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10 reveal">
        <a
          href="https://www.google.com/maps/place/Camping+Municipal+du+Bac/@47.7743566,-0.6767985,17z/data=!4m11!3m10!1s0x480859795f7a0a9b:0x8b5667d9dd46ee68!5m2!4m1!1i2!8m2!3d47.774353!4d-0.6742236!9m1!1b1!16s%2Fg%2F1tf709my"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline btn-sm"
        >
          Voir tous les avis sur Google
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="On vous attend au bord de la Mayenne !"
    subtitle="Réservez votre séjour en ligne ou contactez-nous pour plus d'informations."
    ctaText="Réserver en ligne"
    ctaUrl={content.site.bookingUrl}
  />
</BaseLayout>
