---
import content from '../../data/content.json';
import { url } from '../../utils/paths';
const contentJson = JSON.stringify(content);
---

<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Administration — Camping du Bac</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --forest: #1a3c2a; --green: #3a7d5c; --sage: #6db88a; --moss: #d4e8dc;
      --cream: #faf8f4; --cream-dark: #f0ece4; --river: #2a7ab5;
      --danger: #dc3545; --warning: #ffc107; --radius: 8px;
    }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: var(--cream); color: #333; line-height: 1.5; }

    /* Login */
    .login-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--forest); padding: 1rem; }
    .login-box { background: white; border-radius: 12px; padding: 2.5rem; width: 100%; max-width: 400px; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
    .login-box h1 { color: var(--forest); font-size: 1.5rem; margin-bottom: .25rem; }
    .login-box .subtitle { color: #888; font-size: .875rem; margin-bottom: 1.5rem; }
    .login-box .error { background: #fef2f2; color: var(--danger); border: 1px solid #fecaca; padding: .75rem; border-radius: var(--radius); font-size: .875rem; margin-bottom: 1rem; display: none; }
    .login-box label { display: block; font-size: .8rem; font-weight: 600; color: #555; margin-bottom: .35rem; }
    .login-box input { width: 100%; padding: .65rem .85rem; border: 1px solid #ddd; border-radius: var(--radius); font-size: .9rem; margin-bottom: 1rem; transition: border-color .2s; }
    .login-box input:focus { outline: none; border-color: var(--sage); box-shadow: 0 0 0 3px rgba(109,184,138,.15); }

    /* Admin Layout */
    .admin { display: none; min-height: 100vh; }
    .topbar { background: var(--forest); color: white; padding: .75rem 1.5rem; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar h1 { font-size: 1.1rem; font-weight: 600; }
    .topbar-actions { display: flex; align-items: center; gap: .75rem; }
    .admin-body { display: flex; min-height: calc(100vh - 52px); }

    /* Sidebar */
    .sidebar { width: 240px; background: white; border-right: 1px solid #e5e5e5; padding: 1rem 0; flex-shrink: 0; overflow-y: auto; }
    .sidebar a { display: flex; align-items: center; gap: .65rem; padding: .6rem 1.25rem; color: #555; font-size: .85rem; text-decoration: none; transition: all .15s; border-left: 3px solid transparent; }
    .sidebar a:hover { background: var(--moss); color: var(--forest); }
    .sidebar a.active { background: var(--moss); color: var(--forest); font-weight: 600; border-left-color: var(--sage); }
    .sidebar a svg { width: 18px; height: 18px; flex-shrink: 0; }

    /* Content */
    .content { flex: 1; padding: 2rem 2rem 3.5rem; max-width: 900px; }
    .content h2 { color: var(--forest); font-size: 1.4rem; margin-bottom: .35rem; }
    .content .section-desc { color: #888; font-size: .875rem; margin-bottom: 1.5rem; }
    .section-panel { display: none; }
    .section-panel.active { display: block; }

    /* Form elements */
    .form-group { margin-bottom: 1.25rem; }
    .form-group label { display: block; font-size: .8rem; font-weight: 600; color: #555; margin-bottom: .35rem; text-transform: uppercase; letter-spacing: .3px; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: .6rem .85rem; border: 1px solid #ddd; border-radius: var(--radius); font-size: .875rem; font-family: inherit; transition: border-color .2s; background: white; }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--sage); box-shadow: 0 0 0 3px rgba(109,184,138,.15); }
    .form-group textarea { min-height: 80px; resize: vertical; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }

    /* Cards for items */
    .item-card { background: white; border: 1px solid #e5e5e5; border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1rem; position: relative; transition: border-color .2s; }
    .item-card:hover { border-color: #ccc; }
    .item-card .item-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 1px solid #f0f0f0; cursor: pointer; user-select: none; }
    .item-card.collapsed .item-header { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .item-card .item-title { font-weight: 600; color: var(--forest); font-size: .95rem; }
    .item-card .item-number { background: var(--moss); color: var(--forest); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .8rem; font-weight: 700; }
    .item-card .item-body { overflow: hidden; transition: max-height .3s ease, opacity .2s ease; opacity: 1; }
    .item-card.collapsed .item-body { max-height: 0 !important; opacity: 0; padding-top: 0; }
    .collapse-chevron { transition: transform .2s; color: #999; flex-shrink: 0; }
    .item-card.collapsed .collapse-chevron { transform: rotate(-90deg); }
    .move-buttons { display: flex; flex-direction: column; gap: 1px; }
    .move-buttons button { background: #f5f5f5; border: 1px solid #e5e5e5; border-radius: 3px; cursor: pointer; padding: 2px 6px; font-size: .7rem; color: #666; line-height: 1; }
    .move-buttons button:hover { background: var(--moss); color: var(--forest); }
    .move-buttons button:disabled { opacity: .25; cursor: default; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: .5rem; padding: .55rem 1.1rem; border: none; border-radius: var(--radius); font-size: .85rem; font-weight: 600; cursor: pointer; transition: all .15s; font-family: inherit; }
    .btn-primary { background: var(--sage); color: white; }
    .btn-primary:hover { background: var(--green); }
    .btn-secondary { background: #f5f5f5; color: #555; border: 1px solid #ddd; }
    .btn-secondary:hover { background: #eee; }
    .btn-danger { background: white; color: var(--danger); border: 1px solid #fecaca; }
    .btn-danger:hover { background: #fef2f2; }
    .btn-sm { padding: .35rem .75rem; font-size: .8rem; }
    .btn-export { background: var(--river); color: white; }
    .btn-export:hover { background: #1e5f8a; }
    .btn-save { background: var(--sage); color: white; }
    .btn-save:hover { background: var(--green); }
    .btn-publish { background: #e8590c; color: white; }
    .btn-publish:hover { background: #d04a08; }
    .btn-publish:disabled { opacity: .5; cursor: not-allowed; }
    .btn-logout { background: transparent; color: white; border: 1px solid rgba(255,255,255,.2); }
    .btn-logout:hover { background: rgba(255,255,255,.1); }
    .btn-back { background: transparent; color: white; border: none; font-size: .85rem; opacity: .7; }
    .btn-back:hover { opacity: 1; }

    /* Modal */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; padding: 1rem; }
    .modal-overlay.open { display: flex; }
    .modal { background: white; border-radius: 12px; padding: 2rem; width: 100%; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
    .modal h3 { color: var(--forest); margin-bottom: .25rem; }
    .modal .modal-desc { color: #888; font-size: .85rem; margin-bottom: 1.25rem; }
    .modal .form-group { margin-bottom: 1rem; }
    .modal .modal-actions { display: flex; gap: .75rem; justify-content: flex-end; margin-top: 1.5rem; }
    .modal .status-msg { font-size: .85rem; margin-top: .75rem; padding: .6rem .85rem; border-radius: var(--radius); }
    .modal .status-msg.success { background: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
    .modal .status-msg.error { background: #fef2f2; color: var(--danger); border: 1px solid #fecaca; }
    .modal .status-msg.loading { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
    .saved-badge { background: var(--moss); color: var(--forest); font-size: .7rem; padding: .15rem .5rem; border-radius: 10px; font-weight: 600; display: none; }
    .saved-badge.visible { display: inline-block; }

    /* Feature tags (for accommodations) */
    .features-input { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; margin-top: .25rem; }
    .feature-tag { background: var(--moss); color: var(--forest); padding: .25rem .65rem; border-radius: 20px; font-size: .8rem; display: flex; align-items: center; gap: .35rem; }
    .feature-tag button { background: none; border: none; color: var(--forest); cursor: pointer; font-size: 1rem; line-height: 1; opacity: .5; }
    .feature-tag button:hover { opacity: 1; }

    /* Tarif items */
    .tarif-item { display: grid; grid-template-columns: 1fr 180px 32px; gap: .5rem; align-items: center; margin-bottom: .5rem; }
    .tarif-item input { padding: .45rem .65rem; font-size: .85rem; }
    .tarif-item .btn-remove { width: 28px; height: 28px; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #fef2f2; border: 1px solid #fecaca; color: var(--danger); cursor: pointer; font-size: 1.1rem; }
    .tarif-item .btn-remove:hover { background: #fee2e2; }

    /* Schedule times */
    .schedule-times { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .25rem; }
    .time-tag { background: var(--river); color: white; padding: .25rem .6rem; border-radius: 20px; font-size: .8rem; display: flex; align-items: center; gap: .35rem; }
    .time-tag button { background: none; border: none; color: white; cursor: pointer; font-size: .9rem; opacity: .6; }
    .time-tag button:hover { opacity: 1; }

    /* Toast */
    .toast { position: fixed; bottom: 3.5rem; right: 2rem; background: var(--forest); color: white; padding: .85rem 1.5rem; border-radius: var(--radius); font-size: .875rem; box-shadow: 0 10px 40px rgba(0,0,0,.2); transform: translateY(120%); transition: transform .3s; z-index: 100; display: flex; align-items: center; gap: .5rem; }
    .toast.show { transform: translateY(0); }
    .toast.toast-error { background: var(--danger); }
    .toast svg { flex-shrink: 0; }

    /* Unsaved badge */
    .unsaved-badge { background: #fef3cd; color: #856404; font-size: .7rem; padding: .2rem .6rem; border-radius: 10px; font-weight: 600; display: none; border: 1px solid var(--warning); }
    .unsaved-badge.visible { display: inline-block; }

    /* Status bar */
    .status-bar { position: fixed; bottom: 0; left: 240px; right: 0; background: white; border-top: 1px solid #e5e5e5; padding: .4rem 1.5rem; font-size: .75rem; color: #888; display: flex; align-items: center; justify-content: space-between; z-index: 30; }

    /* Sidebar status dots */
    .sidebar-status { width: 8px; height: 8px; border-radius: 50%; margin-left: auto; flex-shrink: 0; }
    .sidebar-status.complete { background: #22c55e; }
    .sidebar-status.incomplete { background: #f59e0b; }

    /* Form helpers */
    .form-hint { font-size: .75rem; color: #999; margin-top: .2rem; font-style: italic; }
    .form-section-label { font-size: .8rem; text-transform: uppercase; letter-spacing: .4px; color: var(--forest); font-weight: 700; margin-bottom: .75rem; margin-top: 1.5rem; padding-bottom: .4rem; border-bottom: 2px solid var(--moss); }

    /* Sidebar backdrop (mobile) */
    .sidebar-backdrop { display: none; position: fixed; inset: 0; top: 52px; background: rgba(0,0,0,.4); z-index: 35; }
    .sidebar-backdrop.visible { display: block; }

    /* Spinner */
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { width: 16px; height: 16px; border: 2px solid rgba(30,64,175,.3); border-top-color: #1e40af; border-radius: 50%; animation: spin .6s linear infinite; display: inline-block; vertical-align: middle; margin-right: .35rem; }

    /* Responsive */
    @media (max-width: 768px) {
      .sidebar { display: none; position: fixed; top: 52px; left: 0; bottom: 0; z-index: 40; width: 260px; box-shadow: 4px 0 20px rgba(0,0,0,.1); background: white; }
      .sidebar.open { display: block; }
      .sidebar a { min-height: 44px; }
      .content { padding: 1rem 1rem 3.5rem; }
      .form-row, .form-row-3 { grid-template-columns: 1fr; }
      .tarif-item { grid-template-columns: 1fr 120px 36px; }
      .tarif-item .btn-remove { min-width: 36px; min-height: 36px; }
      .btn { min-height: 40px; }
      .btn-sm { min-height: 38px; padding: .45rem .85rem; }
      .status-bar { left: 0; }
    }
    @media (max-width: 480px) {
      .topbar { flex-wrap: wrap; gap: .5rem; padding: .5rem .75rem; }
      .topbar-actions { width: 100%; justify-content: flex-end; gap: .5rem; flex-wrap: wrap; }
      .topbar-actions .btn-sm { font-size: .75rem; padding: .4rem .65rem; }
    }
  </style>
</head>
<body>

<!-- Login Screen -->
<div id="login-screen" class="login-page">
  <div class="login-box">
    <h1>Camping du Bac</h1>
    <p class="subtitle">Administration du site</p>
    <div id="login-error" class="error"></div>
    <form id="login-form">
      <label for="login-password">Mot de passe</label>
      <input type="password" id="login-password" placeholder="Mot de passe" required autofocus>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:.5rem">Se connecter</button>
    </form>
    <p style="text-align:center;margin-top:1.25rem">
      <a href={url('/')} style="color:#888;font-size:.8rem;text-decoration:none">&larr; Retour au site</a>
    </p>
  </div>
</div>

<!-- Admin Panel -->
<div id="admin-panel" class="admin">
  <!-- Top Bar -->
  <div class="topbar">
    <div style="display:flex;align-items:center;gap:1rem">
      <button class="btn-back" id="menu-toggle" style="display:none">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
      <h1>Administration</h1>
      <span class="unsaved-badge" id="unsaved-badge">Modifications non sauvegardées</span>
    </div>
    <div class="topbar-actions">
      <span class="saved-badge" id="saved-badge">Brouillon sauvegardé</span>
      <button class="btn btn-save btn-sm" onclick="saveLocal()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Enregistrer
      </button>
      <button class="btn btn-publish btn-sm" onclick="openPublishModal()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
        Publier
      </button>
      <a href={url('/')} class="btn btn-logout btn-sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Quitter
      </a>
    </div>
  </div>

  <div class="admin-body">
    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
      <a href="#general" class="active" data-section="general">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        Général <span class="sidebar-status" id="status-general"></span>
      </a>
      <a href="#hero" data-section="hero">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        Accueil / Hero <span class="sidebar-status" id="status-hero"></span>
      </a>
      <a href="#hebergements" data-section="hebergements">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Hébergements <span class="sidebar-status" id="status-hebergements"></span>
      </a>
      <a href="#tarifs" data-section="tarifs">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        Tarifs <span class="sidebar-status" id="status-tarifs"></span>
      </a>
      <a href="#activites" data-section="activites">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><path d="M15 6a1 1 0 100-2 1 1 0 000 2zm1 1.5l-3 4.5h4l2 4.5M5.5 17.5L8 10l4 2 3-3.5"/></svg>
        Activités <span class="sidebar-status" id="status-activites"></span>
      </a>
      <a href="#services" data-section="services">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        Services <span class="sidebar-status" id="status-services"></span>
      </a>
      <a href="#bac" data-section="bac">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20h20M5 20V8l7-5 7 5v12"/><rect x="9" y="12" width="6" height="8"/></svg>
        Le Bac <span class="sidebar-status" id="status-bac"></span>
      </a>
      <a href="#faq" data-section="faq">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        FAQ <span class="sidebar-status" id="status-faq"></span>
      </a>
      <a href="#temoignages" data-section="temoignages">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Témoignages <span class="sidebar-status" id="status-temoignages"></span>
      </a>
      <a href="#environs" data-section="environs">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Aux environs <span class="sidebar-status" id="status-environs"></span>
      </a>
      <div style="border-top:1px solid #e5e5e5;margin:.75rem 0"></div>
      <a href="#parametres" data-section="parametres">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Paramètres GitHub
      </a>
    </nav>
    <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

    <!-- Content Area -->
    <main class="content" id="content-area">

      <!-- GENERAL -->
      <div class="section-panel active" id="panel-general">
        <h2>Informations générales</h2>
        <p class="section-desc">Nom du camping, coordonnées, dates d'ouverture</p>

        <p class="form-section-label">Identité du site</p>
        <div class="form-row">
          <div class="form-group">
            <label>Nom du camping</label>
            <input type="text" data-path="site.name">
          </div>
          <div class="form-group">
            <label>Nom court</label>
            <input type="text" data-path="site.shortName">
            <p class="form-hint">Utilisé dans le pied de page et les onglets du navigateur</p>
          </div>
        </div>
        <div class="form-group">
          <label>Slogan</label>
          <input type="text" data-path="site.tagline">
        </div>
        <div class="form-group">
          <label>Description (SEO)</label>
          <textarea data-path="site.description"></textarea>
          <p class="form-hint">Affichée dans les résultats Google, idéalement 150-160 caractères</p>
        </div>
        <div class="form-row-3">
          <div class="form-group">
            <label>Note</label>
            <input type="text" data-path="site.rating">
            <p class="form-hint">Format libre, ex : 9.6/10</p>
          </div>
          <div class="form-group">
            <label>Source de la note</label>
            <input type="text" data-path="site.ratingSource">
          </div>
          <div class="form-group">
            <label>Nombre d'étoiles</label>
            <input type="number" data-path="site.stars" min="1" max="5">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>URL du site</label>
            <input type="url" data-path="site.url">
          </div>
          <div class="form-group">
            <label>URL de réservation</label>
