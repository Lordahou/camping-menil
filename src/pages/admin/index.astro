function loadGitHubConfig() {
  const cfg = localStorage.getItem('admin_github_config');
  if (cfg) {
    try {
      const c = JSON.parse(cfg);
      document.getElementById('github-token').value = c.token || '';
      document.getElementById('github-owner').value = c.owner || 'Lordahou';
      document.getElementById('github-repo').value = c.repo || 'camping-menil';
      document.getElementById('github-branch').value = c.branch || 'main';
      document.getElementById('github-path').value = c.path || 'src/data/content.json';
    } catch(e) {}
  }
}
function saveGitHubConfig() {
  const cfg = {
    token: document.getElementById('github-token').value,
    owner: document.getElementById('github-owner').value,
    repo: document.getElementById('github-repo').value,
    branch: document.getElementById('github-branch').value,
    path: document.getElementById('github-path').value,
  };
