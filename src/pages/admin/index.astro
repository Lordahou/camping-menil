    <!-- Content Area -->
    <main class="content" id="content-area">

      <!-- DASHBOARD -->
      <div class="section-panel active" id="panel-dashboard">
        <div class="dashboard-welcome">
          <h2>Bienvenue sur votre espace admin</h2>
          <p>Gérez le contenu de votre site Camping du Bac en toute simplicité.</p>
        </div>
        <div class="dashboard-stats" id="dashboard-stats"></div>
        <h3 class="section-subheading">Accès rapide</h3>
        <div class="quick-links" id="quick-links"></div>
      </div>

      <!-- GENERAL -->
      <div class="section-panel" id="panel-general">
        <h2>Informations générales</h2>
        <p class="section-desc">Nom du camping, coordonnées, dates d'ouverture</p>
        <h3 class="section-subheading">Identité du site</h3>
        <div class="form-row">
          <div class="form-group"><label>Nom du camping</label><input type="text" data-path="site.name"></div>
          <div class="form-group"><label>Nom court</label><input type="text" data-path="site.shortName"></div>
        </div>
        <div class="form-group"><label>Slogan</label><input type="text" data-path="site.tagline"></div>
        <div class="form-group"><label>Description (SEO)</label><textarea data-path="site.description"></textarea></div>
        <div class="form-row-3">
          <div class="form-group"><label>Note</label><input type="text" data-path="site.rating"></div>
          <div class="form-group"><label>Source de la note</label><input type="text" data-path="site.ratingSource"></div>
          <div class="form-group"><label>Nombre d'étoiles</label><input type="number" data-path="site.stars" min="1" max="5"></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>URL du site</label><input type="url" data-path="site.url"></div>
          <div class="form-group"><label>URL de réservation</label><input type="url" data-path="site.bookingUrl"></div>
        </div>
        <h3 class="section-subheading">Contact</h3>
        <div class="form-row">
          <div class="form-group"><label>Adresse</label><input type="text" data-path="contact.address"></div>
          <div class="form-group"><label>Ville</label><input type="text" data-path="contact.city"></div>
        </div>
        <div class="form-row-3">
          <div class="form-group"><label>Code postal</label><input type="text" data-path="contact.postalCode"></div>
          <div class="form-group"><label>Département</label><input type="text" data-path="contact.department"></div>
          <div class="form-group"><label>Région</label><input type="text" data-path="contact.region"></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Téléphone</label><input type="tel" data-path="contact.phone"></div>
          <div class="form-group"><label>Email</label><input type="email" data-path="contact.email"></div>
        </div>
        <div class="form-group"><label>Email mairie</label><input type="email" data-path="contact.emailMairie"></div>
        <h3 class="section-subheading">Dates d'ouverture</h3>
        <div class="form-row">
          <div class="form-group"><label>Emplacements — début</label><input type="text" data-path="openingDates.emplacements.start"></div>
          <div class="form-group"><label>Emplacements — fin</label><input type="text" data-path="openingDates.emplacements.end"></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Chalets</label><input type="text" data-path="openingDates.chalets"></div>
          <div class="form-group"><label>Maison éclusière</label><input type="text" data-path="openingDates.maisonEclusiere"></div>
        </div>
      </div>

      <!-- HERO -->
      <div class="section-panel" id="panel-hero">
        <h2>Page d'accueil — Hero</h2>
        <p class="section-desc">Titre, sous-titre, boutons et image principale</p>
        <div class="form-group"><label>Titre principal</label><input type="text" data-path="hero.title"></div>
        <div class="form-group"><label>Sous-titre</label><input type="text" data-path="hero.subtitle"></div>
        <div class="form-row">
          <div class="form-group"><label>Bouton 1 — texte</label><input type="text" data-path="hero.cta1.text"></div>
          <div class="form-group"><label>Bouton 1 — URL</label><input type="text" data-path="hero.cta1.url"></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Bouton 2 — texte</label><input type="text" data-path="hero.cta2.text"></div>
          <div class="form-group"><label>Bouton 2 — URL</label><input type="text" data-path="hero.cta2.url"></div>
        </div>
        <div class="form-group"><label>Image</label><div class="image-picker" id="hero-image-picker"></div></div>
        <div class="form-group"><label>Texte alternatif de l'image</label><input type="text" data-path="hero.imageAlt"></div>
        <h3 class="section-subheading">Points forts (highlights)</h3>
        <div id="highlights-list"></div>
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addHighlight()">+ Ajouter un point fort</button>
      </div>

      <!-- HEBERGEMENTS -->
      <div class="section-panel" id="panel-hebergements">
        <h2>Hébergements</h2>
        <p class="section-desc">Emplacements, chalets, bivouac et maison éclusière</p>
        <div id="accommodations-list"></div>
      </div>

      <!-- TARIFS -->
      <div class="section-panel" id="panel-tarifs">
        <h2>Tarifs</h2>
        <p class="section-desc">Grilles tarifaires pour chaque type d'hébergement et les locations</p>
        <div class="form-group"><label>Note générale sur les tarifs</label><textarea data-path="tarifs.note"></textarea></div>
        <div class="form-group"><label>Note sur les moyens de paiement</label><input type="text" data-path="tarifs.paymentNote"></div>
        <div id="tarifs-sections"></div>
      </div>

      <!-- ACTIVITES -->
      <div class="section-panel" id="panel-activites">
        <h2>Activités</h2>
        <p class="section-desc">Activités disponibles au camping et aux alentours</p>
        <div id="activities-list"></div>
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addActivity()">+ Ajouter une activité</button>
      </div>

      <!-- SERVICES -->
      <div class="section-panel" id="panel-services">
        <h2>Services</h2>
        <p class="section-desc">Services proposés au camping</p>
        <div id="services-list"></div>
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addService()">+ Ajouter un service</button>
      </div>

      <!-- BAC -->
      <div class="section-panel" id="panel-bac">
        <h2>Le Bac de Ménil</h2>
        <p class="section-desc">Informations, tarifs et horaires du bac</p>
        <div class="form-group"><label>Titre</label><input type="text" data-path="bac.title"></div>
        <div class="form-group"><label>Description</label><textarea data-path="bac.description" style="min-height:100px"></textarea></div>
        <div class="form-group"><label>Détails</label><textarea data-path="bac.details"></textarea></div>
        <div class="form-row">
          <div class="form-group"><label>Tarif</label><input type="text" data-path="bac.price"></div>
          <div class="form-group"><label>Restrictions</label><input type="text" data-path="bac.restrictions"></div>
        </div>
        <h3 class="section-subheading">Horaires basse saison</h3>
        <div class="form-group"><label>Période</label><input type="text" data-path="bac.schedules.lowSeason.period"></div>
        <div class="form-group">
          <label>Horaires</label>
          <div class="schedule-times" id="low-season-times"></div>
          <div style="margin-top:.5rem;display:flex;gap:.5rem">
            <input type="text" id="low-season-new" placeholder="ex: 14h30" style="width:120px;padding:.35rem .65rem;border:1px solid #ddd;border-radius:var(--radius);font-size:.85rem">
            <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addScheduleTime('low')">Ajouter</button>
          </div>
        </div>
        <h3 class="section-subheading">Horaires haute saison</h3>
        <div class="form-group"><label>Période</label><input type="text" data-path="bac.schedules.highSeason.period"></div>
        <div class="form-group">
          <label>Horaires</label>
          <div class="schedule-times" id="high-season-times"></div>
          <div style="margin-top:.5rem;display:flex;gap:.5rem">
            <input type="text" id="high-season-new" placeholder="ex: 17h00" style="width:120px;padding:.35rem .65rem;border:1px solid #ddd;border-radius:var(--radius);font-size:.85rem">
            <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addScheduleTime('high')">Ajouter</button>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div class="section-panel" id="panel-faq">
        <h2>FAQ</h2>
        <p class="section-desc">Questions fréquentes des visiteurs</p>
        <div id="faq-list"></div>
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addFaq()">+ Ajouter une question</button>
      </div>

      <!-- TEMOIGNAGES -->
      <div class="section-panel" id="panel-temoignages">
        <h2>Témoignages</h2>
        <p class="section-desc">Avis et témoignages des clients</p>
        <div id="testimonials-list"></div>
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addTestimonial()">+ Ajouter un témoignage</button>
      </div>

      <!-- ENVIRONS -->
      <div class="section-panel" id="panel-environs">
        <h2>Aux environs</h2>
        <p class="section-desc">Sites et attractions à proximité du camping</p>
        <div id="surroundings-list"></div>
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.addSurrounding()">+ Ajouter un lieu</button>
      </div>

      <!-- PARAMETRES -->
      <div class="section-panel" id="panel-parametres">
        <h2>Paramètres GitHub</h2>
        <p class="section-desc">Configuration pour publier directement sur le site</p>
        <div class="item-card" id="github-status-card" style="border-left:4px solid #ddd">
          <div style="display:flex;align-items:center;gap:.75rem">
            <div id="github-status-icon" style="width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:#f0f0f0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div>
              <p id="github-status-title" style="font-weight:600;font-size:.9rem;color:#333">Non configuré</p>
              <p id="github-status-desc" style="font-size:.8rem;color:#888">Configurez votre token pour pouvoir publier</p>
            </div>
          </div>
        </div>
        <div class="item-card" style="margin-top:1rem">
          <div class="item-header"><span class="item-title">1. Créer un token GitHub</span></div>
          <div class="item-body">
            <div style="background:#f8faf8;border-radius:10px;padding:1.25rem;margin-bottom:1.25rem">
              <ol style="font-size:.85rem;color:#555;padding-left:1.25rem;display:flex;flex-direction:column;gap:.65rem">
                <li>Connectez-vous sur <strong>github.com</strong></li>
                <li>Allez dans <strong>Settings</strong> &rarr; <strong>Developer settings</strong> &rarr; <strong>Personal access tokens</strong> &rarr; <strong>Tokens (classic)</strong></li>
                <li>Cliquez sur <strong>"Generate new token (classic)"</strong></li>
                <li>Nom : <code>Camping Admin</code> — Expiration : au choix (90 jours recommandé)</li>
                <li>Cochez les droits : <strong><code>repo</code></strong> (tout cocher) et <strong><code>workflow</code></strong></li>
                <li>Cliquez <strong>"Generate token"</strong> et <strong>copiez le token</strong> (commence par <code>ghp_</code>)</li>
              </ol>
            </div>
          </div>
        </div>
        <div class="item-card" style="margin-top:1rem">
          <div class="item-header"><span class="item-title">2. Entrer le token ici</span></div>
          <div class="item-body">
            <div class="form-group">
              <label>Token GitHub (Personal Access Token)</label>
              <input type="password" id="github-token" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" style="font-family:monospace">
              <p class="help-text">Le token est stocké uniquement dans votre navigateur.</p>
            </div>
            <div class="form-row">
              <div class="form-group"><label>Propriétaire / Organisation</label><input type="text" id="github-owner" value="Lordahou"></div>
              <div class="form-group"><label>Nom du dépôt</label><input type="text" id="github-repo" value="camping-menil"></div>
            </div>
            <div class="form-row">
              <div class="form-group"><label>Branche principale</label><input type="text" id="github-branch" value="main"></div>
              <div class="form-group"><label>Chemin du fichier content.json</label><input type="text" id="github-path" value="src/data/content.json"></div>
            </div>
            <div style="display:flex;gap:.75rem;align-items:center">
              <button class="btn btn-primary btn-sm" onclick="window.adminApp.saveGitHubConfig()">Sauvegarder la configuration</button>
              <button class="btn btn-secondary btn-sm" onclick="window.adminApp.testGitHubConnection()">Tester la connexion</button>
            </div>
          </div>
        </div>
        <div class="item-card" style="margin-top:1rem">
          <div class="item-header"><span class="item-title">Alternative : Export local</span></div>
          <div class="item-body">
            <p style="font-size:.85rem;color:#666;margin-bottom:1rem">Téléchargez le fichier <code>content.json</code> modifié et déposez-le manuellement dans votre dépôt.</p>
            <button class="btn btn-export btn-sm" onclick="window.adminApp.exportContent()">Télécharger content.json</button>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<!-- Publish Modal -->
<div class="modal-overlay" id="publish-modal">
  <div class="modal">
    <div id="publish-form-view">
      <h3>Publier les modifications</h3>
      <p class="modal-desc">Un commit sera créé sur GitHub et le site sera automatiquement reconstruit.</p>
      <div class="form-group">
        <label>Message de publication</label>
        <input type="text" id="publish-message" value="Mise à jour du contenu du site" placeholder="Description des modifications...">
      </div>
      <div class="modal-actions">
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.closePublishModal()">Annuler</button>
        <button class="btn btn-publish btn-sm" id="btn-do-publish" onclick="window.adminApp.publishToGitHub()">Publier maintenant</button>
      </div>
    </div>
    <div id="publish-transfer-view" style="display:none">
      <div class="transfer-animation">
        <h3 style="color:var(--forest);margin-bottom:.25rem" id="transfer-title">Transfert en cours...</h3>
        <p class="modal-desc" id="transfer-subtitle">Envoi des données vers GitHub</p>
        <div class="transfer-visual">
          <div class="transfer-icon source">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div class="transfer-pipeline" id="transfer-pipeline">
            <div class="particle"></div><div class="particle"></div><div class="particle"></div>
          </div>
          <div class="transfer-icon target" id="transfer-target">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </div>
        </div>
        <div class="transfer-steps" id="transfer-steps">
          <div class="transfer-step" id="step-read">Lecture du fichier actuel...</div>
          <div class="transfer-step" id="step-images">Envoi des images...</div>
          <div class="transfer-step" id="step-encode">Préparation des données...</div>
          <div class="transfer-step" id="step-push">Envoi du commit sur GitHub...</div>
          <div class="transfer-step" id="step-deploy">Déclenchement du redéploiement...</div>
        </div>
      </div>
      <div id="publish-status" style="margin-top:1rem"></div>
      <div class="modal-actions" id="transfer-actions" style="display:none">
        <button class="btn btn-secondary btn-sm" onclick="window.adminApp.closePublishModal()">Fermer</button>
      </div>
    </div>
  </div>
</div>

<!-- Confirm dialog -->
<div class="confirm-overlay" id="confirm-dialog">
  <div class="confirm-box">
    <h4 id="confirm-title">Supprimer cet élément ?</h4>
    <p id="confirm-message">Cette action est irréversible.</p>
    <div class="confirm-actions">
      <button class="btn btn-secondary btn-sm" onclick="window.adminApp.closeConfirm()">Annuler</button>
      <button class="btn btn-danger btn-sm" id="confirm-btn" style="background:var(--danger);color:white;border:none">Supprimer</button>
    </div>
  </div>
</div>

<!-- Token missing modal -->
<div class="modal-overlay" id="token-modal">
  <div class="modal" style="max-width:540px">
    <div style="text-align:center;margin-bottom:1.25rem">
      <div style="width:56px;height:56px;background:#fff3cd;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto .75rem">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#b45309" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <h3 style="color:var(--forest);margin-bottom:.35rem">Token GitHub requis</h3>
      <p class="modal-desc" style="margin-bottom:0">Pour publier, configurez d'abord votre connexion GitHub.</p>
    </div>
    <div style="background:#f8faf8;border-radius:10px;padding:1.25rem;margin-bottom:1.25rem">
      <p style="font-size:.85rem;font-weight:600;color:var(--forest);margin-bottom:.75rem">Comment faire ?</p>
      <ol style="font-size:.82rem;color:#555;padding-left:1.25rem;display:flex;flex-direction:column;gap:.5rem">
        <li>Allez sur <strong>github.com</strong> &rarr; Settings &rarr; Developer settings &rarr; Personal access tokens &rarr; <strong>Tokens (classic)</strong></li>
        <li>Cliquez <strong>"Generate new token (classic)"</strong></li>
        <li>Cochez les droits <strong><code>repo</code></strong> et <strong><code>workflow</code></strong></li>
        <li>Copiez le token et collez-le dans <strong>Paramètres GitHub</strong></li>
      </ol>
    </div>
    <div class="modal-actions" style="justify-content:center">
      <button class="btn btn-secondary btn-sm" onclick="window.adminApp.closeTokenModal()">Plus tard</button>
      <button class="btn btn-primary btn-sm" onclick="window.adminApp.closeTokenModal();window.adminApp.navigateTo('parametres')">Configurer maintenant</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
  <span id="toast-text"></span>
</div>


<script is:inline define:vars={{ contentJson, basePath: import.meta.env.BASE_URL }}>
(function() {
  "use strict";

  // ─── Utilities ──────────────────────────────────────────────────────────
  function esc(str) {
    if (str == null) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function $(id) { return document.getElementById(id); }

  function showToast(msg) {
    $('toast-text').textContent = msg;
    $('toast').classList.add('show');
    setTimeout(function() { $('toast').classList.remove('show'); }, 3000);
  }

  function getPath(obj, path) {
    return path.split('.').reduce(function(o, k) { return o && o[k]; }, obj);
  }

  function setPath(obj, path, val) {
    var keys = path.split('.');
    var last = keys.pop();
    var target = keys.reduce(function(o, k) { o[k] = o[k] || {}; return o[k]; }, obj);
    target[last] = val;
  }

  // ─── State ──────────────────────────────────────────────────────────────
  var data = JSON.parse(contentJson);
  var hasChanges = false;
  var autoSaveTimer = null;
  var pendingConfirm = null;
  var pendingImageUploads = {};
  var hasDraft = false;

  // Load draft from localStorage
  try {
    var savedDraft = localStorage.getItem('admin_content_draft');
    if (savedDraft) {
      var parsed = JSON.parse(savedDraft);
      if (parsed && Array.isArray(parsed.accommodations) && Array.isArray(parsed.activities)) {
        data = parsed;
        hasDraft = true;
      } else {
        localStorage.removeItem('admin_content_draft');
      }
    }
  } catch(e) { localStorage.removeItem('admin_content_draft'); }

  // ─── Mark changed ─────────────────────────────────────────────────────
  function markChanged() {
    hasChanges = true;
    $('unsaved-dot').classList.add('visible');
    if (autoSaveTimer) clearTimeout(autoSaveTimer);
    autoSaveTimer = setTimeout(function() {
      localStorage.setItem('admin_content_draft', JSON.stringify(data));
      $('saved-badge').classList.add('visible');
    }, 30000);
  }

  // ─── Navigation ─────────────────────────────────────────────────────────
  function navigateTo(section) {
    document.querySelectorAll('.sidebar a').forEach(function(l) { l.classList.remove('active'); });
    var link = document.querySelector('[data-section="' + section + '"]');
    if (link) link.classList.add('active');
    document.querySelectorAll('.section-panel').forEach(function(p) { p.classList.remove('active'); });
    $('panel-' + section).classList.add('active');
    $('sidebar').classList.remove('open');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ─── Dashboard ──────────────────────────────────────────────────────────
  function renderDashboard() {
    var stats = [
      { n: (data.accommodations || []).length, l: 'Hébergements' },
      { n: (data.activities || []).length, l: 'Activités' },
      { n: (data.services || []).length, l: 'Services' },
      { n: (data.faq || []).length, l: 'FAQ' },
      { n: (data.testimonials || []).length, l: 'Témoignages' },
      { n: (data.surroundings || []).length, l: 'Aux environs' }
    ];
    $('dashboard-stats').innerHTML = stats.map(function(s) {
      return '<div class="stat-card"><div class="stat-number">' + s.n + '</div><div class="stat-label">' + s.l + '</div></div>';
    }).join('');

    var links = [
      { s: 'general', l: 'Modifier les infos générales' },
      { s: 'hero', l: "Page d'accueil" },
      { s: 'hebergements', l: 'Gérer les hébergements' },
      { s: 'tarifs', l: 'Mettre à jour les tarifs' },
      { s: 'parametres', l: 'Configurer GitHub' }
    ];
    $('quick-links').innerHTML = links.map(function(lnk) {
      return '<div class="quick-link" onclick="window.adminApp.navigateTo(\'' + lnk.s + '\')">' + esc(lnk.l) + '</div>';
    }).join('');
  }

  // ─── Image Picker ─────────────────────────────────────────────────────
  function getImageSrc(imagePath) {
    if (pendingImageUploads[imagePath] && pendingImageUploads[imagePath].dataUrl) {
      return pendingImageUploads[imagePath].dataUrl;
    }
    if (imagePath && imagePath.charAt(0) === '/') {
      return basePath.replace(/\/$/, '') + imagePath;
    }
    return imagePath || '';
  }

  function renderImagePicker(containerId, imagePath, onPathChange) {
    var container = $(containerId);
    if (!container) return;
    var src = getImageSrc(imagePath);
    var hasPending = pendingImageUploads[imagePath];
    var hasImg = !!imagePath;

    container.className = 'image-picker' + (hasImg ? ' has-image' : '');

    var previewHtml;
    if (hasImg && src) {
      previewHtml = '<img src="' + esc(src) + '" alt="Aperçu">';
    } else {
      previewHtml = '<div class="no-image"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="m21 15-5-5L5 21"></path></svg>Aucune image</div>';
    }

    container.innerHTML = '<div class="image-picker-preview">' + previewHtml + '</div>' +
      '<div class="image-picker-actions">' +
        '<label class="btn-upload"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg> Importer' +
          '<input type="file" accept="image/*" onchange="window.adminApp.handleImageUpload(this, \'' + containerId + '\')">' +
        '</label>' +
        '<span class="image-picker-path">' + (imagePath ? esc(imagePath) : 'Aucun fichier') + '</span>' +
        (hasPending ? '<span class="image-picker-badge">Nouvelle</span>' : '') +
      '</div>';

    var img = container.querySelector('img');
    if (img) {
      img.onerror = function() { this.parentElement.innerHTML = '<div class="no-image">Image introuvable</div>'; };
    }
    container._onPathChange = onPathChange;
  }

  function handleImageUpload(input, containerId) {
    var file = input.files[0];
    if (!file) return;
    var container = $(containerId);
    if (!container) return;

    var reader = new FileReader();
    reader.onload = function(e) {
      var dataUrl = e.target.result;
      var ext = file.name.split('.').pop().toLowerCase();
      var cleanName = file.name.replace(/\.[^.]+$/, '').toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
      var folder = '/images/';
      var target = container.dataset.imageTarget;
      if (target === 'accommodations') folder = '/images/hebergements/';
      else if (target === 'activities') folder = '/images/activites/';
      else if (containerId === 'hero-image-picker') folder = '/images/hero/';

      var newPath = folder + cleanName + '.' + ext;
      pendingImageUploads[newPath] = { base64: dataUrl.split(',')[1], mimeType: file.type, dataUrl: dataUrl };
      if (container._onPathChange) container._onPathChange(newPath);
      markChanged();
    };
    reader.readAsDataURL(file);
  }

  function initHeroImagePicker() {
    renderImagePicker('hero-image-picker', (data.hero && data.hero.image) || '', function(newPath) {
      data.hero.image = newPath;
      initHeroImagePicker();
    });
  }

  function initAccommodationImagePickers() {
    (data.accommodations || []).forEach(function(a, i) {
      renderImagePicker('acc-image-picker-' + i, a.image || '', function(newPath) {
        data.accommodations[i].image = newPath;
        renderImagePicker('acc-image-picker-' + i, newPath, data.accommodations[i]._imgCb || arguments.callee);
      });
    });
  }

  function initActivityImagePickers() {
    (data.activities || []).forEach(function(a, i) {
      renderImagePicker('act-image-picker-' + i, a.image || '', function(newPath) {
        data.activities[i].image = newPath;
        renderImagePicker('act-image-picker-' + i, newPath, arguments.callee);
      });
    });
  }

  // ─── Populate forms ───────────────────────────────────────────────────
  function populateAllForms() {
    document.querySelectorAll('[data-path]').forEach(function(input) {
      var val = getPath(data, input.dataset.path);
      if (val !== undefined && val !== null) input.value = val;
      input.addEventListener('input', function() {
        var v = input.type === 'number' ? Number(input.value) : input.value;
        setPath(data, input.dataset.path, v);
        markChanged();
      });
    });

    renderHighlights();
    renderAccommodations();
    renderTarifs();
    renderActivities();
    renderServices();
    renderScheduleTimes();
    renderFaq();
    renderTestimonials();
    renderSurroundings();
    initHeroImagePicker();
  }

  // ─── Highlights ─────────────────────────────────────────────────────────
  function renderHighlights() {
    var c = $('highlights-list');
    if (!c) return;
    c.innerHTML = '';
    var iconOptions = ['river','bike','star','boat','location','activity'];
    (data.highlights || []).forEach(function(h, i) {
      var optionsHtml = iconOptions.map(function(ic) {
        return '<option value="' + ic + '"' + (h.icon === ic ? ' selected' : '') + '>' + ic + '</option>';
      }).join('');
      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + esc(h.title || 'Point fort ' + (i+1)) + '</span>' +
          '<div style="display:flex;gap:.5rem;align-items:center">' +
            '<span class="item-number">' + (i+1) + '</span>' +
            '<button class="btn btn-danger btn-sm" onclick="window.adminApp.confirmRemoveHighlight(' + i + ')">Supprimer</button>' +
          '</div>' +
        '</div>' +
        '<div class="item-body">' +
          '<div class="form-row-3">' +
            '<div class="form-group"><label>Icône</label><select onchange="window.adminApp.data.highlights[' + i + '].icon=this.value;window.adminApp.markChanged()">' + optionsHtml + '</select></div>' +
            '<div class="form-group"><label>Titre</label><input type="text" value="' + esc(h.title) + '" oninput="window.adminApp.data.highlights[' + i + '].title=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Description</label><input type="text" value="' + esc(h.description) + '" oninput="window.adminApp.data.highlights[' + i + '].description=this.value;window.adminApp.markChanged()"></div>' +
          '</div>' +
        '</div></div>';
    });
  }

  function addHighlight() {
    if (!data.highlights) data.highlights = [];
    data.highlights.push({ icon: 'star', title: '', description: '' });
    renderHighlights(); markChanged();
  }

  function confirmRemoveHighlight(i) {
    showConfirm('Supprimer ce point fort ?', 'L\'élément sera supprimé.', function() {
      data.highlights.splice(i, 1);
      renderHighlights(); markChanged();
    });
  }

  // ─── Accommodations ─────────────────────────────────────────────────────
  function renderAccommodations() {
    var c = $('accommodations-list');
    if (!c) return;
    c.innerHTML = '';
    (data.accommodations || []).forEach(function(a, i) {
      var featuresHtml = (a.features || []).map(function(f, fi) {
        return '<span class="feature-tag">' + esc(f) + '<button onclick="window.adminApp.removeFeature(' + i + ',' + fi + ')">&times;</button></span>';
      }).join('');

      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + esc(a.title || 'Hébergement ' + (i+1)) + '</span><span class="item-number">' + (i+1) + '</span></div>' +
        '<div class="item-body">' +
          '<div class="form-row">' +
            '<div class="form-group"><label>Titre</label><input type="text" value="' + esc(a.title) + '" oninput="window.adminApp.data.accommodations[' + i + '].title=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Sous-titre</label><input type="text" value="' + esc(a.subtitle) + '" oninput="window.adminApp.data.accommodations[' + i + '].subtitle=this.value;window.adminApp.markChanged()"></div>' +
          '</div>' +
          '<div class="form-group"><label>Description</label><textarea oninput="window.adminApp.data.accommodations[' + i + '].description=this.value;window.adminApp.markChanged()">' + esc(a.description) + '</textarea></div>' +
          '<div class="form-row-3">' +
            '<div class="form-group"><label>Capacité</label><input type="text" value="' + esc(a.capacity) + '" oninput="window.adminApp.data.accommodations[' + i + '].capacity=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Check-in</label><input type="text" value="' + esc(a.checkin || '') + '" oninput="window.adminApp.data.accommodations[' + i + '].checkin=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Check-out</label><input type="text" value="' + esc(a.checkout || '') + '" oninput="window.adminApp.data.accommodations[' + i + '].checkout=this.value;window.adminApp.markChanged()"></div>' +
          '</div>' +
          '<div class="form-group"><label>Image</label><div class="image-picker" id="acc-image-picker-' + i + '" data-image-target="accommodations"></div></div>' +
          '<div class="form-group"><label>Texte alternatif</label><input type="text" value="' + esc(a.imageAlt || '') + '" oninput="window.adminApp.data.accommodations[' + i + '].imageAlt=this.value;window.adminApp.markChanged()"></div>' +
          '<div class="form-group"><label>Caractéristiques</label>' +
            '<div class="features-input">' + featuresHtml +
              '<div style="display:flex;gap:.35rem">' +
                '<input type="text" id="feat-input-' + i + '" placeholder="Ajouter..." style="width:140px;padding:.3rem .6rem;font-size:.8rem;border:1px solid #ddd;border-radius:20px">' +
                '<button class="btn btn-secondary btn-sm" onclick="window.adminApp.addFeature(' + i + ')">+</button>' +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div></div>';
    });
    initAccommodationImagePickers();
  }

  function addFeature(accIdx) {
    var input = $('feat-input-' + accIdx);
    if (input && input.value.trim()) {
      if (!data.accommodations[accIdx].features) data.accommodations[accIdx].features = [];
      data.accommodations[accIdx].features.push(input.value.trim());
      input.value = '';
      renderAccommodations(); markChanged();
    }
  }

  function removeFeature(accIdx, featIdx) {
    data.accommodations[accIdx].features.splice(featIdx, 1);
    renderAccommodations(); markChanged();
  }

  // ─── Tarifs ───────────────────────────────────────────────────────────
  function renderTarifs() {
    var c = $('tarifs-sections');
    if (!c) return;
    c.innerHTML = '';
    ['emplacements', 'chalets', 'bivouac', 'rentals'].forEach(function(key) {
      var t = data.tarifs && data.tarifs[key];
      if (!t) return;
      var itemsHtml = (t.items || []).map(function(item, ii) {
        return '<div class="tarif-item">' +
          '<input type="text" value="' + esc(item.label) + '" oninput="window.adminApp.data.tarifs[\'' + key + '\'].items[' + ii + '].label=this.value;window.adminApp.markChanged()">' +
          '<input type="text" value="' + esc(item.price) + '" oninput="window.adminApp.data.tarifs[\'' + key + '\'].items[' + ii + '].price=this.value;window.adminApp.markChanged()">' +
          '<button class="btn-remove" onclick="window.adminApp.removeTarifItem(\'' + key + '\',' + ii + ')">&times;</button>' +
        '</div>';
      }).join('');

      var footnoteHtml = '';
      if (t.footnote !== undefined) {
        footnoteHtml = '<div class="form-group"><label>Note de bas</label><input type="text" value="' + esc(t.footnote || '') + '" oninput="window.adminApp.data.tarifs[\'' + key + '\'].footnote=this.value;window.adminApp.markChanged()"></div>';
      }

      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + esc(t.title) + '</span></div>' +
        '<div class="form-row">' +
          '<div class="form-group"><label>Titre</label><input type="text" value="' + esc(t.title) + '" oninput="window.adminApp.data.tarifs[\'' + key + '\'].title=this.value;window.adminApp.markChanged()"></div>' +
          '<div class="form-group"><label>Description</label><input type="text" value="' + esc(t.description) + '" oninput="window.adminApp.data.tarifs[\'' + key + '\'].description=this.value;window.adminApp.markChanged()"></div>' +
        '</div>' +
        '<div class="form-group"><label>Tarifs</label>' + itemsHtml +
          '<button class="btn btn-secondary btn-sm" style="margin-top:.5rem" onclick="window.adminApp.addTarifItem(\'' + key + '\')">+ Ajouter un tarif</button>' +
        '</div>' +
        footnoteHtml +
      '</div>';
    });
  }

  function addTarifItem(key) {
    data.tarifs[key].items.push({ label: '', price: '' });
    renderTarifs(); markChanged();
  }

  function removeTarifItem(key, idx) {
    data.tarifs[key].items.splice(idx, 1);
    renderTarifs(); markChanged();
  }

  // ─── Activities ─────────────────────────────────────────────────────────
  function renderActivities() {
    var c = $('activities-list');
    if (!c) return;
    c.innerHTML = '';
    (data.activities || []).forEach(function(a, i) {
      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + (esc(a.title) || 'Activité ' + (i+1)) + '</span>' +
          '<div style="display:flex;gap:.5rem;align-items:center">' +
            '<span class="item-number">' + (i+1) + '</span>' +
            '<button class="btn btn-danger btn-sm" onclick="window.adminApp.confirmRemoveActivity(' + i + ')">Supprimer</button>' +
          '</div>' +
        '</div>' +
        '<div class="item-body">' +
          '<div class="form-row">' +
            '<div class="form-group"><label>Titre</label><input type="text" value="' + esc(a.title) + '" oninput="window.adminApp.data.activities[' + i + '].title=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Catégorie</label><input type="text" value="' + esc(a.category || '') + '" oninput="window.adminApp.data.activities[' + i + '].category=this.value;window.adminApp.markChanged()"></div>' +
          '</div>' +
          '<div class="form-group"><label>Description</label><textarea oninput="window.adminApp.data.activities[' + i + '].description=this.value;window.adminApp.markChanged()">' + esc(a.description) + '</textarea></div>' +
          '<div class="form-group"><label>Image</label><div class="image-picker" id="act-image-picker-' + i + '" data-image-target="activities"></div></div>' +
          '<div class="form-group"><label>Tarif</label><input type="text" value="' + esc(a.price || '') + '" oninput="window.adminApp.data.activities[' + i + '].price=this.value;window.adminApp.markChanged()"></div>' +
        '</div></div>';
    });
    initActivityImagePickers();
  }

  function addActivity() {
    if (!data.activities) data.activities = [];
    data.activities.push({ title: '', description: '', image: '', category: '', price: '' });
    renderActivities(); markChanged();
  }

  function confirmRemoveActivity(i) {
    showConfirm('Supprimer cette activité ?', 'L\'activité sera supprimée.', function() {
      data.activities.splice(i, 1);
      renderActivities(); markChanged();
    });
  }

  // ─── Services ─────────────────────────────────────────────────────────
  function renderServices() {
    var c = $('services-list');
    if (!c) return;
    c.innerHTML = '';
    var iconOptions = ['wifi','electric','laundry','accessible','pets','bike-parking','playground','fishing','shower','parking','bbq'];
    (data.services || []).forEach(function(s, i) {
      var optionsHtml = iconOptions.map(function(ic) {
        return '<option value="' + ic + '"' + (s.icon === ic ? ' selected' : '') + '>' + ic + '</option>';
      }).join('');
      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + (esc(s.title) || 'Service ' + (i+1)) + '</span>' +
          '<div style="display:flex;gap:.5rem;align-items:center">' +
            '<span class="item-number">' + (i+1) + '</span>' +
            '<button class="btn btn-danger btn-sm" onclick="window.adminApp.confirmRemoveService(' + i + ')">Supprimer</button>' +
          '</div>' +
        '</div>' +
        '<div class="item-body">' +
          '<div class="form-row-3">' +
            '<div class="form-group"><label>Icône</label><select onchange="window.adminApp.data.services[' + i + '].icon=this.value;window.adminApp.markChanged()">' + optionsHtml + '</select></div>' +
            '<div class="form-group"><label>Titre</label><input type="text" value="' + esc(s.title) + '" oninput="window.adminApp.data.services[' + i + '].title=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Description</label><input type="text" value="' + esc(s.description) + '" oninput="window.adminApp.data.services[' + i + '].description=this.value;window.adminApp.markChanged()"></div>' +
          '</div>' +
        '</div></div>';
    });
  }

  function addService() {
    if (!data.services) data.services = [];
    data.services.push({ icon: 'wifi', title: '', description: '' });
    renderServices(); markChanged();
  }

  function confirmRemoveService(i) {
    showConfirm('Supprimer ce service ?', 'Le service sera supprimé.', function() {
      data.services.splice(i, 1);
      renderServices(); markChanged();
    });
  }

  // ─── Schedule times ───────────────────────────────────────────────────
  function renderScheduleTimes() {
    ['low', 'high'].forEach(function(season) {
      var key = season === 'low' ? 'lowSeason' : 'highSeason';
      var c = $(season + '-season-times');
      if (!c || !data.bac || !data.bac.schedules || !data.bac.schedules[key]) return;
      c.innerHTML = '';
      (data.bac.schedules[key].times || []).forEach(function(t, i) {
        c.innerHTML += '<span class="time-tag">' + esc(t) + '<button onclick="window.adminApp.removeScheduleTime(\'' + season + '\',' + i + ')">&times;</button></span>';
      });
    });
  }

  function addScheduleTime(season) {
    var key = season === 'low' ? 'lowSeason' : 'highSeason';
    var input = $(season + '-season-new');
    if (input && input.value.trim()) {
      data.bac.schedules[key].times.push(input.value.trim());
      input.value = '';
      renderScheduleTimes(); markChanged();
    }
  }

  function removeScheduleTime(season, i) {
    var key = season === 'low' ? 'lowSeason' : 'highSeason';
    data.bac.schedules[key].times.splice(i, 1);
    renderScheduleTimes(); markChanged();
  }

  // ─── FAQ ──────────────────────────────────────────────────────────────
  function renderFaq() {
    var c = $('faq-list');
    if (!c) return;
    c.innerHTML = '';
    (data.faq || []).forEach(function(f, i) {
      var shortQ = esc(f.question || '').substring(0, 50) + (f.question && f.question.length > 50 ? '...' : '');
      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + shortQ + '</span>' +
          '<div style="display:flex;gap:.5rem;align-items:center">' +
            '<span class="item-number">' + (i+1) + '</span>' +
            '<button class="btn btn-danger btn-sm" onclick="window.adminApp.confirmRemoveFaq(' + i + ')">Supprimer</button>' +
          '</div>' +
        '</div>' +
        '<div class="item-body">' +
          '<div class="form-group"><label>Question</label><input type="text" value="' + esc(f.question) + '" oninput="window.adminApp.data.faq[' + i + '].question=this.value;window.adminApp.markChanged()"></div>' +
          '<div class="form-group"><label>Réponse</label><textarea style="min-height:100px" oninput="window.adminApp.data.faq[' + i + '].answer=this.value;window.adminApp.markChanged()">' + esc(f.answer) + '</textarea></div>' +
        '</div></div>';
    });
  }

  function addFaq() {
    if (!data.faq) data.faq = [];
    data.faq.push({ question: '', answer: '' });
    renderFaq(); markChanged();
  }

  function confirmRemoveFaq(i) {
    showConfirm('Supprimer cette question ?', 'La question sera supprimée.', function() {
      data.faq.splice(i, 1);
      renderFaq(); markChanged();
    });
  }

  // ─── Testimonials ─────────────────────────────────────────────────────
  function renderTestimonials() {
    var c = $('testimonials-list');
    if (!c) return;
    c.innerHTML = '';
    (data.testimonials || []).forEach(function(t, i) {
      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + (esc(t.author) || 'Témoignage ' + (i+1)) + '</span>' +
          '<div style="display:flex;gap:.5rem;align-items:center">' +
            '<span class="item-number">' + (i+1) + '</span>' +
            '<button class="btn btn-danger btn-sm" onclick="window.adminApp.confirmRemoveTestimonial(' + i + ')">Supprimer</button>' +
          '</div>' +
        '</div>' +
        '<div class="item-body">' +
          '<div class="form-group"><label>Témoignage</label><textarea oninput="window.adminApp.data.testimonials[' + i + '].text=this.value;window.adminApp.markChanged()">' + esc(t.text) + '</textarea></div>' +
          '<div class="form-row-3">' +
            '<div class="form-group"><label>Auteur</label><input type="text" value="' + esc(t.author) + '" oninput="window.adminApp.data.testimonials[' + i + '].author=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Source</label><input type="text" value="' + esc(t.origin || '') + '" oninput="window.adminApp.data.testimonials[' + i + '].origin=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Note (1-5)</label><input type="number" min="1" max="5" value="' + (t.rating || 5) + '" oninput="window.adminApp.data.testimonials[' + i + '].rating=Number(this.value);window.adminApp.markChanged()"></div>' +
          '</div>' +
        '</div></div>';
    });
  }

  function addTestimonial() {
    if (!data.testimonials) data.testimonials = [];
    data.testimonials.push({ text: '', author: '', origin: 'Google', rating: 5 });
    renderTestimonials(); markChanged();
  }

  function confirmRemoveTestimonial(i) {
    showConfirm('Supprimer ce témoignage ?', 'Le témoignage sera supprimé.', function() {
      data.testimonials.splice(i, 1);
      renderTestimonials(); markChanged();
    });
  }

  // ─── Surroundings ─────────────────────────────────────────────────────
  function renderSurroundings() {
    var c = $('surroundings-list');
    if (!c) return;
    c.innerHTML = '';
    (data.surroundings || []).forEach(function(s, i) {
      c.innerHTML += '<div class="item-card">' +
        '<div class="item-header"><span class="item-title">' + (esc(s.title) || 'Lieu ' + (i+1)) + '</span>' +
          '<div style="display:flex;gap:.5rem;align-items:center">' +
            '<span class="item-number">' + (i+1) + '</span>' +
            '<button class="btn btn-danger btn-sm" onclick="window.adminApp.confirmRemoveSurrounding(' + i + ')">Supprimer</button>' +
          '</div>' +
        '</div>' +
        '<div class="item-body">' +
          '<div class="form-row-3">' +
            '<div class="form-group"><label>Nom</label><input type="text" value="' + esc(s.title) + '" oninput="window.adminApp.data.surroundings[' + i + '].title=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>Distance</label><input type="text" value="' + esc(s.distance) + '" oninput="window.adminApp.data.surroundings[' + i + '].distance=this.value;window.adminApp.markChanged()"></div>' +
            '<div class="form-group"><label>URL</label><input type="url" value="' + esc(s.url || '') + '" oninput="window.adminApp.data.surroundings[' + i + '].url=this.value;window.adminApp.markChanged()"></div>' +
          '</div>' +
          '<div class="form-group"><label>Description</label><input type="text" value="' + esc(s.description) + '" oninput="window.adminApp.data.surroundings[' + i + '].description=this.value;window.adminApp.markChanged()"></div>' +
        '</div></div>';
    });
  }

  function addSurrounding() {
    if (!data.surroundings) data.surroundings = [];
    data.surroundings.push({ title: '', distance: '', description: '', url: '' });
    renderSurroundings(); markChanged();
  }

  function confirmRemoveSurrounding(i) {
    showConfirm('Supprimer ce lieu ?', 'Le lieu sera supprimé.', function() {
      data.surroundings.splice(i, 1);
      renderSurroundings(); markChanged();
    });
  }

  // ─── Confirm dialog ──────────────────────────────────────────────────
  function showConfirm(title, message, callback) {
    $('confirm-title').textContent = title;
    $('confirm-message').textContent = message;
    pendingConfirm = callback;
    $('confirm-dialog').classList.add('open');
    $('confirm-btn').onclick = function() {
      closeConfirm();
      if (pendingConfirm) pendingConfirm();
    };
  }

  function closeConfirm() {
    $('confirm-dialog').classList.remove('open');
    pendingConfirm = null;
  }

  // ─── Save / Export ────────────────────────────────────────────────────
  function saveLocal() {
    var btn = document.querySelector('.btn-save');
    var originalHTML = btn.innerHTML;
    btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg> Enregistré !';
    btn.style.background = '#065f46';

    localStorage.setItem('admin_content_draft', JSON.stringify(data));
    hasChanges = false;
    $('unsaved-dot').classList.remove('visible');
    $('saved-badge').classList.add('visible');
    showToast('Brouillon enregistré localement');

    setTimeout(function() {
      btn.innerHTML = originalHTML;
      btn.style.background = '';
    }, 1500);
  }

  function exportContent() {
    var json = JSON.stringify(data, null, 2);
    var blob = new Blob([json], { type: 'application/json' });
    var u = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = u; a.download = 'content.json'; a.click();
    URL.revokeObjectURL(u);
    showToast('Fichier content.json téléchargé');
  }

  // ─── GitHub config ────────────────────────────────────────────────────
  function getGitHubConfig() {
    var cfg = localStorage.getItem('admin_github_config');
    if (!cfg) return null;
    try { return JSON.parse(cfg); } catch(e) { return null; }
  }

  function loadGitHubConfig() {
    var cfg = getGitHubConfig();
    if (cfg) {
      if (cfg.token) $('github-token').value = cfg.token;
      if (cfg.owner) $('github-owner').value = cfg.owner;
      if (cfg.repo) $('github-repo').value = cfg.repo;
      if (cfg.branch) $('github-branch').value = cfg.branch;
      if (cfg.path) $('github-path').value = cfg.path;
    }
  }

  function saveGitHubConfig() {
    var cfg = {
      token: $('github-token').value,
      owner: $('github-owner').value,
      repo: $('github-repo').value,
      branch: $('github-branch').value,
      path: $('github-path').value
    };
    localStorage.setItem('admin_github_config', JSON.stringify(cfg));
    updateGitHubStatus();
    showToast('Configuration GitHub sauvegardée');
  }

  function updateGitHubStatus() {
    var cfg = getGitHubConfig();
    var card = $('github-status-card');
    var icon = $('github-status-icon');
    var title = $('github-status-title');
    var desc = $('github-status-desc');

    if (cfg && cfg.token) {
      card.style.borderLeftColor = 'var(--sage)';
      icon.style.background = 'var(--moss)';
      icon.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>';
      title.textContent = 'Configuré';
      title.style.color = 'var(--green)';
      desc.textContent = cfg.owner + '/' + cfg.repo + ' (branche ' + cfg.branch + ')';
    } else {
      card.style.borderLeftColor = '#ffc107';
      icon.style.background = '#fff3cd';
      icon.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#b45309" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
      title.textContent = 'Non configuré';
      title.style.color = '#b45309';
      desc.textContent = 'Configurez votre token pour pouvoir publier';
    }
  }

  async function testGitHubConnection() {
    var cfg = getGitHubConfig();
    if (!cfg || !cfg.token) {
      alert('Token non trouvé. Sauvegardez d\'abord la configuration.');
      return;
    }
    try {
      var res = await fetch('https://api.github.com/repos/' + cfg.owner + '/' + cfg.repo, {
        headers: { 'Authorization': 'token ' + cfg.token, 'Accept': 'application/vnd.github.v3+json' }
      });
      if (res.ok) {
        var repoData = await res.json();
        alert('Connexion réussie !\n\nDépôt : ' + repoData.full_name);
      } else if (res.status === 401) {
        alert('Token invalide ou expiré.');
      } else if (res.status === 404) {
        alert('Dépôt introuvable.');
      } else {
        alert('Erreur (code ' + res.status + ')');
      }
    } catch (err) {
      alert('Erreur réseau : ' + err.message);
    }
  }

  // ─── Publish modal ────────────────────────────────────────────────────
  function openTokenModal() { $('token-modal').classList.add('open'); }
  function closeTokenModal() { $('token-modal').classList.remove('open'); }

  function openPublishModal() {
    var cfg = getGitHubConfig();
    if (!cfg || !cfg.token) { openTokenModal(); return; }
    $('publish-form-view').style.display = 'block';
    $('publish-transfer-view').style.display = 'none';
    $('publish-status').innerHTML = '';
    $('btn-do-publish').disabled = false;
    $('transfer-actions').style.display = 'none';
    document.querySelectorAll('.transfer-step').forEach(function(s) { s.className = 'transfer-step'; });
    $('transfer-pipeline').classList.remove('done');
    $('transfer-target').classList.remove('success');
    $('publish-modal').classList.add('open');
  }

  function closePublishModal() { $('publish-modal').classList.remove('open'); }

  function setStep(stepId, state) {
    $(stepId).className = 'transfer-step ' + state;
  }

  // ─── Publish to GitHub ────────────────────────────────────────────────
  async function publishToGitHub() {
    var cfg = getGitHubConfig();
    if (!cfg || !cfg.token) return;

    $('publish-form-view').style.display = 'none';
    $('publish-transfer-view').style.display = 'block';
    $('transfer-title').textContent = 'Transfert en cours...';
    $('transfer-subtitle').textContent = 'Envoi des données vers GitHub';

    var statusEl = $('publish-status');
    statusEl.innerHTML = '';

    var apiBase = 'https://api.github.com';
    var headers = {
      'Authorization': 'token ' + cfg.token,
      'Accept': 'application/vnd.github.v3+json',
      'Content-Type': 'application/json'
    };

    try {
      // Step 1: Read current file
      setStep('step-read', 'active');
      var getRes = await fetch(apiBase + '/repos/' + cfg.owner + '/' + cfg.repo + '/contents/' + cfg.path + '?ref=' + cfg.branch, { headers: headers });
      if (!getRes.ok && getRes.status !== 404) {
        var errData = await getRes.json();
        throw new Error(errData.message || 'Erreur lecture fichier');
      }
      var currentSha = null;
      if (getRes.ok) {
        var fileData = await getRes.json();
        currentSha = fileData.sha;
      }
      setStep('step-read', 'done');

      // Step 2: Upload images
      var imageKeys = Object.keys(pendingImageUploads);
      if (imageKeys.length > 0) {
        setStep('step-images', 'active');
        for (var idx = 0; idx < imageKeys.length; idx++) {
          var imgPath = imageKeys[idx];
          var imgData = pendingImageUploads[imgPath];
          var repoPath = 'public' + imgPath;
          var imgGetRes = await fetch(apiBase + '/repos/' + cfg.owner + '/' + cfg.repo + '/contents/' + repoPath + '?ref=' + cfg.branch, { headers: headers });
          var imgSha = null;
          if (imgGetRes.ok) { imgSha = (await imgGetRes.json()).sha; }
          var imgPutBody = { message: 'Ajout image: ' + imgPath.split('/').pop(), content: imgData.base64, branch: cfg.branch };
          if (imgSha) imgPutBody.sha = imgSha;
          var imgPutRes = await fetch(apiBase + '/repos/' + cfg.owner + '/' + cfg.repo + '/contents/' + repoPath, { method: 'PUT', headers: headers, body: JSON.stringify(imgPutBody) });
          if (!imgPutRes.ok) {
            var imgErr = await imgPutRes.json();
            throw new Error('Erreur upload image: ' + (imgErr.message || ''));
          }
        }
        for (var k = 0; k < imageKeys.length; k++) delete pendingImageUploads[imageKeys[k]];
        setStep('step-images', 'done');
      } else {
        setStep('step-images', 'done');
      }

      // Step 3: Encode content
      setStep('step-encode', 'active');
      var jsonContent = JSON.stringify(data, null, 2) + '\n';
      var base64Content = btoa(unescape(encodeURIComponent(jsonContent)));
      await new Promise(function(r) { setTimeout(r, 400); });
      setStep('step-encode', 'done');

      // Step 4: Push commit
      setStep('step-push', 'active');
      var commitMessage = $('publish-message').value || 'Mise à jour du contenu';
      var putBody = { message: commitMessage, content: base64Content, branch: cfg.branch };
      if (currentSha) putBody.sha = currentSha;
      var putRes = await fetch(apiBase + '/repos/' + cfg.owner + '/' + cfg.repo + '/contents/' + cfg.path, { method: 'PUT', headers: headers, body: JSON.stringify(putBody) });
      if (!putRes.ok) {
        var putErr = await putRes.json();
        throw new Error(putErr.message || 'Erreur publication');
      }
      var result = await putRes.json();
      var commitUrl = result.commit.html_url;
      setStep('step-push', 'done');

      // Step 5: Deploy
      setStep('step-deploy', 'active');
      await new Promise(function(r) { setTimeout(r, 600); });
      setStep('step-deploy', 'done');

      // Success
      $('transfer-pipeline').classList.add('done');
      $('transfer-target').classList.add('success');
      $('transfer-title').textContent = 'Publié avec succès !';
      $('transfer-subtitle').textContent = 'Le site sera reconstruit automatiquement';

      localStorage.removeItem('admin_content_draft');
      hasChanges = false;
      $('unsaved-dot').classList.remove('visible');
      $('saved-badge').classList.remove('visible');

      statusEl.innerHTML = '<div class="status-msg success"><a href="' + commitUrl + '" target="_blank" style="color:#065f46;text-decoration:underline">Voir le commit sur GitHub</a></div>';
      $('transfer-actions').style.display = 'flex';
      showToast('Modifications publiées sur GitHub');

    } catch (err) {
      document.querySelectorAll('.transfer-step.active').forEach(function(s) { s.className = 'transfer-step error'; });
      $('transfer-pipeline').classList.add('done');
      $('transfer-title').textContent = 'Erreur de transfert';
      $('transfer-subtitle').textContent = 'La publication a échoué';
      statusEl.innerHTML = '<div class="status-msg error">Erreur : ' + esc(err.message) + '</div>';
      $('transfer-actions').style.display = 'flex';
    }
  }

  // ─── Event listeners ──────────────────────────────────────────────────
  // Sidebar navigation
  document.querySelectorAll('.sidebar a').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      navigateTo(link.dataset.section);
    });
  });

  // Mobile menu
  if (window.innerWidth <= 768) $('menu-toggle').style.display = 'block';
  window.addEventListener('resize', function() {
    $('menu-toggle').style.display = window.innerWidth <= 768 ? 'block' : 'none';
  });

  // Keyboard shortcut: Ctrl+S
  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 's') { e.preventDefault(); saveLocal(); }
  });

  // Collapsible cards
  document.addEventListener('click', function(e) {
    var header = e.target.closest('.item-card .item-header');
    if (!header) return;
    if (e.target.closest('button')) return;
    header.closest('.item-card').classList.toggle('collapsed');
  });

  // Close modals on overlay click
  $('confirm-dialog').addEventListener('click', function(e) { if (e.target === e.currentTarget) closeConfirm(); });
  $('publish-modal').addEventListener('click', function(e) { if (e.target === e.currentTarget) closePublishModal(); });
  $('token-modal').addEventListener('click', function(e) { if (e.target === e.currentTarget) closeTokenModal(); });

  // Warn before leaving with unsaved changes
  window.addEventListener('beforeunload', function(e) {
    if (hasChanges) { e.preventDefault(); e.returnValue = ''; }
  });

  // ─── Init ─────────────────────────────────────────────────────────────
  loadGitHubConfig();
  populateAllForms();
  renderDashboard();
  updateGitHubStatus();
  if (hasDraft) $('saved-badge').classList.add('visible');

  // ─── Expose public API ────────────────────────────────────────────────
  window.adminApp = {
    data: data,
    pendingImageUploads: pendingImageUploads,
    markChanged: markChanged,
    navigateTo: navigateTo,
    saveLocal: saveLocal,
    exportContent: exportContent,
    openPublishModal: openPublishModal,
    closePublishModal: closePublishModal,
    publishToGitHub: publishToGitHub,
    showConfirm: showConfirm,
    closeConfirm: closeConfirm,
    addHighlight: addHighlight,
    confirmRemoveHighlight: confirmRemoveHighlight,
    addFeature: addFeature,
    removeFeature: removeFeature,
    addActivity: addActivity,
    confirmRemoveActivity: confirmRemoveActivity,
    addService: addService,
    confirmRemoveService: confirmRemoveService,
    addScheduleTime: addScheduleTime,
    removeScheduleTime: removeScheduleTime,
    addTarifItem: addTarifItem,
    removeTarifItem: removeTarifItem,
    addFaq: addFaq,
    confirmRemoveFaq: confirmRemoveFaq,
    addTestimonial: addTestimonial,
    confirmRemoveTestimonial: confirmRemoveTestimonial,
    addSurrounding: addSurrounding,
    confirmRemoveSurrounding: confirmRemoveSurrounding,
    saveGitHubConfig: saveGitHubConfig,
    testGitHubConnection: testGitHubConnection,
    openTokenModal: openTokenModal,
    closeTokenModal: closeTokenModal,
    handleImageUpload: handleImageUpload
  };

})();
</script>

</body>
</html>
