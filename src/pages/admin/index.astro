---
import content from '../../data/content.json';
import { url } from '../../utils/paths';
const contentJson = JSON.stringify(content);
---

<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Administration — Camping du Bac</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --forest: #1a3c2a; --green: #3a7d5c; --sage: #6db88a; --moss: #d4e8dc;
      --cream: #f8faf8; --cream-dark: #f0ece4; --river: #2a7ab5;
      --danger: #dc3545; --warning: #ffc107; --radius: 10px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.06);
      --shadow-md: 0 4px 12px rgba(0,0,0,.08);
      --shadow-lg: 0 12px 40px rgba(0,0,0,.12);
    }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: var(--cream); color: #333; line-height: 1.6; }

    /* Admin Layout */
    .admin { min-height: 100vh; }
    .topbar { background: linear-gradient(135deg, var(--forest) 0%, #244f38 100%); color: white; padding: .85rem 1.5rem; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; box-shadow: 0 2px 12px rgba(0,0,0,.15); }
    .topbar-left { display: flex; align-items: center; gap: 1rem; }
    .topbar-logo { width: 32px; height: 32px; background: rgba(255,255,255,.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .topbar h1 { font-size: 1.1rem; font-weight: 600; letter-spacing: -.01em; }
    .topbar h1 span { font-weight: 400; opacity: .7; font-size: .85rem; margin-left: .5rem; }
    .topbar-actions { display: flex; align-items: center; gap: .5rem; }
    .admin-body { display: flex; min-height: calc(100vh - 56px); }

    /* Sidebar */
    .sidebar { width: 250px; background: white; border-right: 1px solid #e8ebe8; padding: .75rem 0; flex-shrink: 0; overflow-y: auto; position: sticky; top: 56px; height: calc(100vh - 56px); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; }
    .sidebar-section { padding: 0 .75rem; margin-bottom: .25rem; }
    .sidebar-section-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: #999; padding: .75rem .75rem .35rem; }
    .sidebar a { display: flex; align-items: center; gap: .65rem; padding: .55rem .85rem; color: #666; font-size: .84rem; text-decoration: none; transition: all .2s; border-radius: 8px; margin: 1px 0; }
    .sidebar a:hover { background: var(--moss); color: var(--forest); transform: translateX(2px); }
    .sidebar a.active { background: var(--moss); color: var(--forest); font-weight: 600; box-shadow: inset 3px 0 0 var(--sage); }
    .sidebar a svg { width: 18px; height: 18px; flex-shrink: 0; opacity: .7; }
    .sidebar a.active svg { opacity: 1; }
    .sidebar-version { padding: .75rem 1rem; margin-top: auto; font-size: .7rem; color: #bbb; text-align: center; border-top: 1px solid #e8ebe8; }

    /* Content */
    .content { flex: 1; padding: 2rem 2.5rem; max-width: 920px; }
    .content h2 { color: var(--forest); font-size: 1.5rem; margin-bottom: .35rem; font-weight: 700; letter-spacing: -.02em; }
    .content .section-desc { color: #888; font-size: .875rem; margin-bottom: 1.75rem; }
    .section-panel { display: none; animation: fadeIn .3s ease; }
    .section-panel.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    /* Dashboard */
    .dashboard-welcome { background: linear-gradient(135deg, var(--forest) 0%, var(--green) 100%); color: white; border-radius: 16px; padding: 2rem 2.5rem; margin-bottom: 2rem; position: relative; overflow: hidden; }
    .dashboard-welcome::after { content: ''; position: absolute; right: -30px; top: -30px; width: 180px; height: 180px; background: rgba(255,255,255,.06); border-radius: 50%; }
    .dashboard-welcome h2 { color: white; font-size: 1.6rem; margin-bottom: .35rem; }
    .dashboard-welcome p { opacity: .85; font-size: .95rem; }
    .dashboard-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: white; border-radius: var(--radius); padding: 1.25rem; text-align: center; border: 1px solid #e8ebe8; box-shadow: var(--shadow-sm); transition: all .2s; cursor: default; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .stat-card .stat-number { font-size: 1.8rem; font-weight: 700; color: var(--forest); line-height: 1; }
    .stat-card .stat-label { font-size: .75rem; color: #888; margin-top: .35rem; text-transform: uppercase; letter-spacing: .5px; }
    .quick-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: .75rem; }
    .quick-link { background: white; border: 1px solid #e8ebe8; border-radius: var(--radius); padding: 1rem 1.25rem; display: flex; align-items: center; gap: .75rem; text-decoration: none; color: #333; font-size: .9rem; font-weight: 500; transition: all .2s; cursor: pointer; }
    .quick-link:hover { background: var(--moss); border-color: var(--sage); transform: translateX(4px); }
    .quick-link svg { color: var(--sage); flex-shrink: 0; }

    /* Form elements */
    .form-group { margin-bottom: 1.25rem; }
    .form-group label { display: block; font-size: .75rem; font-weight: 600; color: #777; margin-bottom: .4rem; text-transform: uppercase; letter-spacing: .4px; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: .65rem .9rem; border: 1.5px solid #e0e4e0; border-radius: var(--radius); font-size: .875rem; font-family: inherit; transition: all .2s; background: white; }
    .form-group input:hover, .form-group textarea:hover { border-color: #c0c8c0; }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: var(--sage); box-shadow: 0 0 0 3px rgba(109,184,138,.15); }
    .form-group textarea { min-height: 80px; resize: vertical; }
    .form-group .help-text { font-size: .75rem; color: #aaa; margin-top: .3rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
    .section-subheading { font-size: 1rem; color: var(--forest); margin: 1.75rem 0 .85rem; padding-bottom: .5rem; border-bottom: 2px solid var(--moss); display: flex; align-items: center; gap: .5rem; }

    /* Cards for items */
    .item-card { background: white; border: 1px solid #e8ebe8; border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; position: relative; box-shadow: var(--shadow-sm); transition: all .2s; }
    .item-card:hover { box-shadow: var(--shadow-md); }
    .item-card .item-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 1px solid #f0f0f0; cursor: pointer; user-select: none; }
    .item-card .item-header:hover .item-title { color: var(--green); }
    .item-card .item-title { font-weight: 600; color: var(--forest); font-size: .95rem; transition: color .2s; display: flex; align-items: center; gap: .5rem; }
    .item-card .item-title::before { content: ''; display: inline-block; width: 6px; height: 6px; border: 2px solid var(--sage); border-top: 0; border-left: 0; transform: rotate(45deg); transition: transform .2s; flex-shrink: 0; }
    .item-card.collapsed .item-title::before { transform: rotate(-45deg); }
    .item-card.collapsed .item-body { display: none; }
    .item-card .item-number { background: var(--moss); color: var(--forest); width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .75rem; font-weight: 700; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: .5rem; padding: .55rem 1.1rem; border: none; border-radius: var(--radius); font-size: .85rem; font-weight: 600; cursor: pointer; transition: all .2s; font-family: inherit; }
    .btn:active { transform: scale(.97); }
    .btn-primary { background: var(--sage); color: white; }
    .btn-primary:hover { background: var(--green); box-shadow: 0 2px 8px rgba(58,125,92,.3); }
    .btn-secondary { background: #f5f5f5; color: #555; border: 1px solid #ddd; }
    .btn-secondary:hover { background: #eee; border-color: #ccc; }
    .btn-danger { background: white; color: var(--danger); border: 1px solid #fecaca; font-size: .75rem; }
    .btn-danger:hover { background: #fef2f2; }
    .btn-sm { padding: .4rem .85rem; font-size: .8rem; }
    .btn-export { background: var(--river); color: white; }
    .btn-export:hover { background: #1e5f8a; }
    .btn-save { background: var(--sage); color: white; border-radius: 8px; }
    .btn-save:hover { background: var(--green); }
    .btn-publish { background: linear-gradient(135deg, #e8590c, #d04a08); color: white; border-radius: 8px; }
    .btn-publish:hover { box-shadow: 0 2px 8px rgba(232,89,12,.4); transform: translateY(-1px); }
    .btn-publish:disabled { opacity: .5; cursor: not-allowed; transform: none; }
    .btn-logout { background: rgba(255,255,255,.1); color: white; border: 1px solid rgba(255,255,255,.2); border-radius: 8px; }
    .btn-logout:hover { background: rgba(255,255,255,.2); }
    .btn-back { background: transparent; color: white; border: none; font-size: .85rem; opacity: .7; cursor: pointer; }
    .btn-back:hover { opacity: 1; }

    /* Modal */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; padding: 1rem; }
    .modal-overlay.open { display: flex; }
    .modal { background: white; border-radius: 12px; padding: 2rem; width: 100%; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
    .modal h3 { color: var(--forest); margin-bottom: .25rem; }
    .modal .modal-desc { color: #888; font-size: .85rem; margin-bottom: 1.25rem; }
    .modal .modal-actions { display: flex; gap: .75rem; justify-content: flex-end; margin-top: 1.5rem; }
    .modal .status-msg { font-size: .85rem; margin-top: .75rem; padding: .6rem .85rem; border-radius: var(--radius); }
    .modal .status-msg.success { background: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
    .modal .status-msg.error { background: #fef2f2; color: var(--danger); border: 1px solid #fecaca; }
    .modal .status-msg.loading { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
    .saved-badge { background: rgba(255,255,255,.15); color: white; font-size: .7rem; padding: .2rem .6rem; border-radius: 10px; font-weight: 600; display: none; border: 1px solid rgba(255,255,255,.2); }
    .saved-badge.visible { display: inline-flex; align-items: center; gap: .3rem; }

    /* Confirm dialog */
    .confirm-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 300; align-items: center; justify-content: center; }
    .confirm-overlay.open { display: flex; }
    .confirm-box { background: white; border-radius: 14px; padding: 1.75rem; width: 100%; max-width: 380px; box-shadow: var(--shadow-lg); text-align: center; animation: confirmIn .2s ease; }
    .confirm-box h4 { color: var(--forest); margin-bottom: .5rem; font-size: 1.05rem; }
    .confirm-box p { color: #888; font-size: .85rem; margin-bottom: 1.25rem; }
    .confirm-box .confirm-actions { display: flex; gap: .5rem; justify-content: center; }
    @keyframes confirmIn { from { transform: scale(.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }

    /* Feature tags */
    .features-input { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; margin-top: .25rem; }
    .feature-tag { background: var(--moss); color: var(--forest); padding: .25rem .65rem; border-radius: 20px; font-size: .8rem; display: flex; align-items: center; gap: .35rem; }
    .feature-tag button { background: none; border: none; color: var(--forest); cursor: pointer; font-size: 1rem; line-height: 1; opacity: .5; }
    .feature-tag button:hover { opacity: 1; }

    /* Tarif items */
    .tarif-item { display: grid; grid-template-columns: 1fr 180px 32px; gap: .5rem; align-items: center; margin-bottom: .5rem; }
    .tarif-item input { padding: .45rem .65rem; font-size: .85rem; }
    .tarif-item .btn-remove { width: 28px; height: 28px; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #fef2f2; border: 1px solid #fecaca; color: var(--danger); cursor: pointer; font-size: 1.1rem; }
    .tarif-item .btn-remove:hover { background: #fee2e2; }

    /* Schedule times */
    .schedule-times { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .25rem; }
    .time-tag { background: var(--river); color: white; padding: .25rem .6rem; border-radius: 20px; font-size: .8rem; display: flex; align-items: center; gap: .35rem; }
    .time-tag button { background: none; border: none; color: white; cursor: pointer; font-size: .9rem; opacity: .6; }
    .time-tag button:hover { opacity: 1; }

    /* Transfer animation */
    .transfer-animation { text-align: center; padding: 1.5rem 0; }
    .transfer-visual { display: flex; align-items: center; justify-content: center; gap: 1rem; margin: 1.5rem 0; }
    .transfer-icon { width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .transfer-icon.source { background: var(--moss); color: var(--forest); }
    .transfer-icon.target { background: #f0f0f0; color: #333; }
    .transfer-icon.target.success { background: #ecfdf5; color: #065f46; animation: pulse-success .5s; }
    .transfer-pipeline { position: relative; width: 120px; height: 4px; background: #e5e5e5; border-radius: 2px; overflow: hidden; }
    .transfer-pipeline .particle { position: absolute; width: 20px; height: 100%; background: var(--sage); border-radius: 2px; animation: particle-flow 1s ease-in-out infinite; }
    .transfer-pipeline .particle:nth-child(2) { animation-delay: .33s; }
    .transfer-pipeline .particle:nth-child(3) { animation-delay: .66s; }
    .transfer-pipeline.done { background: var(--sage); }
    .transfer-pipeline.done .particle { display: none; }
    .transfer-step { font-size: .8rem; color: #888; margin-top: .75rem; transition: color .2s; }
    .transfer-step.active { color: var(--forest); font-weight: 600; }
    .transfer-step.done { color: var(--sage); }
    .transfer-steps { display: flex; flex-direction: column; gap: .4rem; text-align: left; margin-top: 1.5rem; padding: 0 1rem; }
    .transfer-step::before { content: ''; display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #ddd; margin-right: .5rem; vertical-align: middle; transition: background .2s; }
    .transfer-step.active::before { background: var(--river); animation: step-pulse .8s infinite; }
    .transfer-step.done::before { background: var(--sage); }
    .transfer-step.error::before { background: var(--danger); }
    .transfer-step.error { color: var(--danger); }
    @keyframes particle-flow { 0% { left: -20px; opacity: 0; } 20% { opacity: 1; } 80% { opacity: 1; } 100% { left: 100%; opacity: 0; } }
    @keyframes pulse-success { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }
    @keyframes step-pulse { 0%, 100% { opacity: 1; } 50% { opacity: .4; } }

    /* Toast */
    .toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(120%); background: var(--forest); color: white; padding: .85rem 1.5rem; border-radius: 12px; font-size: .875rem; box-shadow: var(--shadow-lg); transition: transform .4s cubic-bezier(.175,.885,.32,1.275); z-index: 100; display: flex; align-items: center; gap: .5rem; white-space: nowrap; }
    .toast.show { transform: translateX(-50%) translateY(0); }

    /* Unsaved indicator */
    .unsaved-dot { width: 8px; height: 8px; background: var(--warning); border-radius: 50%; display: none; animation: pulse-dot 2s infinite; }
    .unsaved-dot.visible { display: block; }
    @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: .4; } }

    /* Image picker */
    .image-picker { border: 2px dashed #d0d5d0; border-radius: var(--radius); padding: .75rem; background: #fafbfa; transition: all .2s; }
    .image-picker:hover { border-color: var(--sage); }
    .image-picker.has-image { border-style: solid; border-color: #e0e4e0; }
    .image-picker-preview { position: relative; width: 100%; max-height: 200px; border-radius: 8px; overflow: hidden; margin-bottom: .6rem; background: #f0f0f0; display: flex; align-items: center; justify-content: center; }
    .image-picker-preview img { width: 100%; max-height: 200px; object-fit: cover; display: block; border-radius: 8px; }
    .image-picker-preview .no-image { color: #bbb; font-size: .85rem; padding: 2.5rem 1rem; text-align: center; }
    .image-picker-preview .no-image svg { display: block; margin: 0 auto .5rem; opacity: .4; }
    .image-picker-actions { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; }
    .image-picker-actions .btn-upload { background: var(--moss); color: var(--forest); border: none; padding: .4rem .85rem; border-radius: 8px; font-size: .8rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: .4rem; transition: all .2s; }
    .image-picker-actions .btn-upload:hover { background: var(--sage); color: white; }
    .image-picker-path { flex: 1; font-size: .75rem; color: #999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
    .image-picker-badge { background: var(--warning); color: #333; font-size: .65rem; font-weight: 700; padding: .15rem .5rem; border-radius: 10px; white-space: nowrap; }
    .image-picker input[type="file"] { display: none; }

    /* Empty state */
    .empty-state { text-align: center; padding: 2.5rem 1rem; color: #aaa; }
    .empty-state p { font-size: .9rem; }

    /* Responsive */
    @media (max-width: 768px) {
      .sidebar { display: none; position: fixed; top: 56px; left: 0; bottom: 0; z-index: 40; width: 260px; box-shadow: 4px 0 20px rgba(0,0,0,.1); }
      .sidebar.open { display: flex; }
      .content { padding: 1rem; }
      .form-row, .form-row-3 { grid-template-columns: 1fr; }
      .tarif-item { grid-template-columns: 1fr 120px 28px; }
      .dashboard-stats { grid-template-columns: repeat(2, 1fr); }
      .quick-links { grid-template-columns: 1fr; }
      .topbar-actions .btn span.btn-label { display: none; }
    }
  </style>
</head>
<body>

<div id="admin-panel" class="admin">
  <!-- Top Bar -->
  <div class="topbar">
    <div class="topbar-left">
      <button class="btn-back" id="menu-toggle" style="display:none" onclick="document.getElementById('sidebar').classList.toggle('open')">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
      <div class="topbar-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
      </div>
      <h1>Camping du Bac <span>Administration</span></h1>
      <div class="unsaved-dot" id="unsaved-dot" title="Modifications non enregistrées"></div>
    </div>
    <div class="topbar-actions">
      <span class="saved-badge" id="saved-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        Brouillon sauvegardé
      </span>
      <button class="btn btn-save btn-sm" onclick="window.adminApp.saveLocal()" title="Ctrl+S">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        <span class="btn-label">Enregistrer</span>
      </button>
      <button class="btn btn-publish btn-sm" onclick="window.adminApp.openPublishModal()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
        <span class="btn-label">Publier</span>
      </button>
      <a href={url('/')} class="btn btn-logout btn-sm" title="Retour au site">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        <span class="btn-label">Voir le site</span>
      </a>
    </div>
  </div>

  <div class="admin-body">
    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-section-label">Tableau de bord</div>
        <a href="#dashboard" class="active" data-section="dashboard">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Accueil
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Contenu du site</div>
        <a href="#general" data-section="general">
