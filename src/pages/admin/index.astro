<div class="toast" id="toast"></div>

<script is:inline define:vars={{ contentJson, basePath: import.meta.env.BASE_URL }}>
// ─── State ──────────────────────────────────────────────────────────────
const originalContent = contentJson;
let data = JSON.parse(contentJson);
let hasChanges = false;
let autoSaveTimer = null;
let lastSaveTime = null;
let pendingDeleteAction = null;
const expandedCards = new Set();
const PASSWORD_HASH = '310a70698c30bd3a2fe34393d9d9d739856b655ca070ccd0bed2e5c654bbb97b';

// Load saved draft from localStorage if available
const savedDraft = localStorage.getItem('admin_content_draft');
if (savedDraft) {
  try { data = JSON.parse(savedDraft); } catch(e) { /* ignore bad data */ }
}

// ─── Auth ───────────────────────────────────────────────────────────────
async function sha256(text) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(text));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
}

document.getElementById('login-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const pw = document.getElementById('login-password').value;
  const hash = await sha256(pw);
  if (hash === PASSWORD_HASH) {
    sessionStorage.setItem('admin_auth', '1');
    showAdmin();
  } else {
    const err = document.getElementById('login-error');
    err.textContent = 'Mot de passe incorrect.';
    err.style.display = 'block';
  }
});

function showAdmin() {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('admin-panel').style.display = 'block';
  loadGitHubConfig();
  populateAllForms();
  if (savedDraft) {
    document.getElementById('saved-badge').classList.add('visible');
    document.getElementById('saved-badge').textContent = 'Brouillon chargé';
  }
}

if (sessionStorage.getItem('admin_auth') === '1') showAdmin();

// ─── Navigation ─────────────────────────────────────────────────────────
document.querySelectorAll('.sidebar a').forEach(link => {
  link.addEventListener('click', (e) => {
    e.preventDefault();
    const section = link.dataset.section;
    document.querySelectorAll('.sidebar a').forEach(l => l.classList.remove('active'));
    link.classList.add('active');
    document.querySelectorAll('.section-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel-' + section).classList.add('active');
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebar-backdrop').classList.remove('visible');
  });
});

// ─── Mobile menu ────────────────────────────────────────────────────────
function updateMenuToggle() {
  document.getElementById('menu-toggle').style.display = window.innerWidth <= 768 ? 'block' : 'none';
}
updateMenuToggle();
window.addEventListener('resize', updateMenuToggle);

document.getElementById('menu-toggle').addEventListener('click', () => {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebar-backdrop').classList.toggle('visible');
});
document.getElementById('sidebar-backdrop').addEventListener('click', () => {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-backdrop').classList.remove('visible');
});

// ─── Data helpers ───────────────────────────────────────────────────────
function getPath(obj, path) {
  return path.split('.').reduce((o, k) => o?.[k], obj);
}
function setPath(obj, path, val) {
  const keys = path.split('.');
  const last = keys.pop();
  const target = keys.reduce((o, k) => o[k] = o[k] || {}, obj);
  target[last] = val;
}
function markChanged() {
  hasChanges = true;
  document.getElementById('unsaved-badge').classList.add('visible');
  document.getElementById('saved-badge').classList.remove('visible');
  // Debounced auto-save
  clearTimeout(autoSaveTimer);
  autoSaveTimer = setTimeout(autoSaveLocal, 2000);
  updateSidebarStatus();
}
function autoSaveLocal() {
  localStorage.setItem('admin_content_draft', JSON.stringify(data));
  lastSaveTime = new Date();
  updateStatusBar();
  const badge = document.getElementById('saved-badge');
  badge.textContent = 'Auto-sauvegardé';
  badge.classList.add('visible');
  setTimeout(() => badge.classList.remove('visible'), 2500);
}

// ─── Confirm Delete ─────────────────────────────────────────────────────
function confirmDelete(itemName, deleteFn) {
  document.getElementById('confirm-message').textContent = 'Voulez-vous vraiment supprimer « ' + (itemName || 'cet élément') + ' » ?';
  pendingDeleteAction = deleteFn;
  document.getElementById('confirm-modal').classList.add('open');
}
function closeConfirmModal() {
  document.getElementById('confirm-modal').classList.remove('open');
  pendingDeleteAction = null;
}
function executeDelete() {
  if (pendingDeleteAction) pendingDeleteAction();
  closeConfirmModal();
}
document.getElementById('confirm-modal').addEventListener('click', (e) => {
  if (e.target === e.currentTarget) closeConfirmModal();
});

// ─── Collapsible Cards ──────────────────────────────────────────────────
function toggleCard(cardId, e) {
  if (e && (e.target.closest('button.btn-danger') || e.target.closest('.move-buttons') || e.target.closest('select'))) return;
  const card = document.getElementById(cardId);
  if (!card) return;
  card.classList.toggle('collapsed');
  if (card.classList.contains('collapsed')) {
    expandedCards.delete(cardId);
  } else {
    expandedCards.add(cardId);
  }
}

// ─── Move Items ─────────────────────────────────────────────────────────
function moveItem(arrayPath, fromIdx, direction) {
  const arr = getPath(data, arrayPath);
  const toIdx = fromIdx + direction;
  if (toIdx < 0 || toIdx >= arr.length) return;
  [arr[fromIdx], arr[toIdx]] = [arr[toIdx], arr[fromIdx]];
  // Update expanded cards tracking
  const prefix = arrayPath.replace(/\./g, '-');
  const fromId = 'card-' + prefix + '-' + fromIdx;
  const toId = 'card-' + prefix + '-' + toIdx;
  const fromExpanded = expandedCards.has(fromId);
  const toExpanded = expandedCards.has(toId);
  if (fromExpanded) { expandedCards.delete(fromId); expandedCards.add(toId); }
  else { expandedCards.delete(toId); }
  if (toExpanded) { expandedCards.add(fromId); }
  else { expandedCards.delete(fromId); }
  markChanged();
}
function moveHighlight(i, d) { moveItem('highlights', i, d); renderHighlights(); }
function moveActivity(i, d) { moveItem('activities', i, d); renderActivities(); }
function moveService(i, d) { moveItem('services', i, d); renderServices(); }
function moveFaq(i, d) { moveItem('faq', i, d); renderFaq(); }
function moveTestimonial(i, d) { moveItem('testimonials', i, d); renderTestimonials(); }
function moveSurrounding(i, d) { moveItem('surroundings', i, d); renderSurroundings(); }

// ─── Sidebar Status ─────────────────────────────────────────────────────
function updateSidebarStatus() {
  const checks = {
    general: () => data.site.name && data.contact.phone && data.contact.email,
    hero: () => data.hero.title && data.hero.image,
    hebergements: () => data.accommodations.length > 0 && data.accommodations.every(a => a.title),
    tarifs: () => ['emplacements','chalets'].every(k => data.tarifs[k]?.items?.length > 0),
    activites: () => data.activities.length > 0 && data.activities.every(a => a.title),
    services: () => data.services.length > 0 && data.services.every(s => s.title),
    bac: () => data.bac.title && data.bac.description,
    faq: () => data.faq.length > 0 && data.faq.every(f => f.question && f.answer),
    temoignages: () => data.testimonials.length > 0 && data.testimonials.every(t => t.text && t.author),
    environs: () => data.surroundings.length > 0 && data.surroundings.every(s => s.title),
  };
  Object.entries(checks).forEach(([section, check]) => {
    const el = document.getElementById('status-' + section);
    if (!el) return;
    try {
      el.className = 'sidebar-status ' + (check() ? 'complete' : 'incomplete');
    } catch(e) { el.className = 'sidebar-status incomplete'; }
  });
}

// ─── Status Bar ─────────────────────────────────────────────────────────
function updateStatusBar() {
  const timeEl = document.getElementById('status-bar-time');
  if (lastSaveTime) {
    timeEl.textContent = 'Dernière sauvegarde : ' + lastSaveTime.toLocaleTimeString('fr-FR');
  }
}

// ─── Populate simple fields ─────────────────────────────────────────────
function populateAllForms() {
  document.querySelectorAll('[data-path]').forEach(input => {
    const val = getPath(data, input.dataset.path);
    if (val !== undefined) input.value = val;
    input.addEventListener('input', () => {
      const v = input.type === 'number' ? Number(input.value) : input.value;
      setPath(data, input.dataset.path, v);
      markChanged();
    });
  });

  renderHighlights();
  renderAccommodations();
  renderTarifs();
  renderActivities();
  renderServices();
  renderScheduleTimes();
  renderFaq();
  renderTestimonials();
  renderSurroundings();
  updateSidebarStatus();
}

// ─── Card HTML helper ───────────────────────────────────────────────────
const chevronSvg = '<svg class="collapse-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';

function cardHeader(cardId, title, index, total, moveFn, deleteFn, deleteLabel) {
  const collapsed = expandedCards.has(cardId) ? '' : ' collapsed';
  const moveHtml = moveFn ? `<div class="move-buttons">
    <button onclick="event.stopPropagation();${moveFn}(${index},-1)" ${index===0?'disabled':''} title="Monter">&#9650;</button>
    <button onclick="event.stopPropagation();${moveFn}(${index},1)" ${index>=total-1?'disabled':''} title="Descendre">&#9660;</button>
  </div>` : '';

  return `<div class="item-card${collapsed}" id="${cardId}">
    <div class="item-header" onclick="toggleCard('${cardId}',event)">
      <div style="display:flex;align-items:center;gap:.5rem">
        ${chevronSvg}
        <span class="item-title">${title}</span>
