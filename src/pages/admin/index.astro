}

// ─── Change Summary ─────────────────────────────────────────────────────
function getChangeSummary() {
  const orig = JSON.parse(originalContent);
  const sections = [];
  if (JSON.stringify(orig.site) !== JSON.stringify(data.site) ||
      JSON.stringify(orig.contact) !== JSON.stringify(data.contact) ||
      JSON.stringify(orig.openingDates) !== JSON.stringify(data.openingDates)) sections.push('Général');
  if (JSON.stringify(orig.hero) !== JSON.stringify(data.hero)) sections.push('Hero');
  if (JSON.stringify(orig.highlights) !== JSON.stringify(data.highlights)) sections.push('Points forts');
  if (JSON.stringify(orig.accommodations) !== JSON.stringify(data.accommodations)) sections.push('Hébergements');
  if (JSON.stringify(orig.tarifs) !== JSON.stringify(data.tarifs)) sections.push('Tarifs');
  if (JSON.stringify(orig.activities) !== JSON.stringify(data.activities)) sections.push('Activités');
  if (JSON.stringify(orig.services) !== JSON.stringify(data.services)) sections.push('Services');
  if (JSON.stringify(orig.bac) !== JSON.stringify(data.bac)) sections.push('Le Bac');
  if (JSON.stringify(orig.faq) !== JSON.stringify(data.faq)) sections.push('FAQ');
  if (JSON.stringify(orig.testimonials) !== JSON.stringify(data.testimonials)) sections.push('Témoignages');
  if (JSON.stringify(orig.surroundings) !== JSON.stringify(data.surroundings)) sections.push('Environs');
  return sections;
}

// ─── Publish modal ──────────────────────────────────────────────────────
function openPublishModal() {
  const cfg = getGitHubConfig();
  if (!cfg || !cfg.token) {
    showToast('Configurez votre token GitHub dans Paramètres d\'abord', 'error');
    document.querySelectorAll('.sidebar a').forEach(l => l.classList.remove('active'));
    document.querySelector('[data-section="parametres"]').classList.add('active');
    document.querySelectorAll('.section-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel-parametres').classList.add('active');
    return;
  }
  document.getElementById('publish-status').innerHTML = '';
  document.getElementById('btn-do-publish').disabled = false;

  // Show change summary
  const changed = getChangeSummary();
  const summaryEl = document.getElementById('publish-summary');
  if (changed.length > 0) {
    summaryEl.innerHTML = '<strong>' + changed.length + ' section(s) modifiée(s) :</strong> ' + changed.join(', ');
    summaryEl.style.display = 'block';
  } else {
    summaryEl.innerHTML = 'Aucune modification détectée par rapport à la version en ligne.';
    summaryEl.style.display = 'block';
  }

  document.getElementById('publish-modal').classList.add('open');
}
function closePublishModal() {
  document.getElementById('publish-modal').classList.remove('open');
}

// ─── Publish to GitHub ──────────────────────────────────────────────────
async function publishToGitHub() {
  const cfg = getGitHubConfig();
  if (!cfg || !cfg.token) return;

  const statusEl = document.getElementById('publish-status');
  const btnPublish = document.getElementById('btn-do-publish');
  btnPublish.disabled = true;

  statusEl.innerHTML = '<div class="status-msg loading"><span class="spinner"></span> Étape 1/3 — Lecture du fichier actuel...</div>';

  const apiBase = 'https://api.github.com';
  const headers = {
    'Authorization': 'token ' + cfg.token,
    'Accept': 'application/vnd.github.v3+json',
    'Content-Type': 'application/json',
  };

  try {
    const getRes = await fetch(
      apiBase + '/repos/' + cfg.owner + '/' + cfg.repo + '/contents/' + cfg.path + '?ref=' + cfg.branch,
      { headers }
    );

    if (!getRes.ok && getRes.status !== 404) {
      const err = await getRes.json();
      throw new Error(err.message || 'Erreur lors de la lecture du fichier');
    }

    let currentSha = null;
    if (getRes.ok) {
      const fileData = await getRes.json();
      currentSha = fileData.sha;
    }

    statusEl.innerHTML = '<div class="status-msg loading"><span class="spinner"></span> Étape 2/3 — Envoi des modifications...</div>';

    const jsonContent = JSON.stringify(data, null, 2) + '\n';
    const base64Content = btoa(unescape(encodeURIComponent(jsonContent)));

    const commitMessage = document.getElementById('publish-message').value || 'Mise à jour du contenu';
    const putBody = {
      message: commitMessage,
      content: base64Content,
      branch: cfg.branch,
    };
    if (currentSha) putBody.sha = currentSha;

    const putRes = await fetch(
      apiBase + '/repos/' + cfg.owner + '/' + cfg.repo + '/contents/' + cfg.path,
      { method: 'PUT', headers, body: JSON.stringify(putBody) }
    );

    if (!putRes.ok) {
      const err = await putRes.json();
      throw new Error(err.message || 'Erreur lors de la publication');
    }

    statusEl.innerHTML = '<div class="status-msg loading"><span class="spinner"></span> Étape 3/3 — Finalisation...</div>';

    const result = await putRes.json();
    const commitUrl = result.commit.html_url;

    localStorage.removeItem('admin_content_draft');
    hasChanges = false;
    document.getElementById('unsaved-badge').classList.remove('visible');
    document.getElementById('saved-badge').classList.remove('visible');

    statusEl.innerHTML = '<div class="status-msg success">Publié avec succès ! Le site sera reconstruit automatiquement.<br><a href="' + commitUrl + '" target="_blank" style="color:#065f46;text-decoration:underline">Voir le commit</a></div>';
    showToast('Modifications publiées sur GitHub');

  } catch (err) {
    statusEl.innerHTML = '<div class="status-msg error">Erreur : ' + esc(err.message) + '</div>';
    btnPublish.disabled = false;
  }
}

// ─── Utilities ──────────────────────────────────────────────────────────
function esc(str) {
  if (str === undefined || str === null) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function showToast(msg, type) {
  type = type || 'success';
  const t = document.getElementById('toast');
  t.className = 'toast' + (type === 'error' ? ' toast-error' : '');
  const icon = type === 'success'
    ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>'
    : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
  t.innerHTML = icon + '<span>' + msg + '</span>';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// Warn before leaving with unsaved changes
window.addEventListener('beforeunload', (e) => {
  if (hasChanges) { e.preventDefault(); e.returnValue = ''; }
});

// Close modals on overlay click
document.getElementById('publish-modal').addEventListener('click', (e) => {
  if (e.target === e.currentTarget) closePublishModal();
});
</script>

</body>
</html>
