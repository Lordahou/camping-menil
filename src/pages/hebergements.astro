---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CTABanner from '../components/CTABanner.astro';
import content from '../data/content.json';
import { url } from '../utils/paths';
---

<BaseLayout
  title="Nos hébergements — Camping emplacement chalet gîte Mayenne Château-Gontier"
  description="Découvrez nos hébergements au Camping du Bac : 34 emplacements ombragés, 5 chalets tout confort, tentes bivouac pour cyclistes et une maison éclusière de caractère."
>
  <Hero
    title="Nos hébergements"
    subtitle="Du simple emplacement au gîte de caractère — trouvez votre façon de vivre le bord de Mayenne"
    image="/images/hebergements/chalets.jpg"
    imageAlt="Hébergements du Camping du Bac de Ménil"
    size="medium"
  />

  <!-- INTRO -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <span class="badge mb-4">4 types d'hébergements</span>
      <h2 class="text-forest mb-6">Un hébergement pour chaque façon de voyager</h2>
      <p class="text-gray-600 text-lg leading-relaxed">
        Campeur avec tente et vélo, famille en quête de confort, couple cherchant un gîte
        de caractère ou groupe souhaitant privatiser une maison historique : le Camping du Bac
        a pensé à chacun d'entre vous.
      </p>
    </div>
  </section>

  <!-- EMPLACEMENTS -->
  <section id="emplacements" class="py-16 lg:py-24 bg-cream-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img
              src={url(content.accommodations[0].image)}
              alt={content.accommodations[0].imageAlt}
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
            <span class="absolute top-4 left-4 badge bg-white/90 text-forest text-xs">{content.accommodations[0].count} emplacements</span>
          </div>
        </div>
        <div class="reveal reveal-delay-2">
          <span class="badge mb-4">Emplacements</span>
          <h2 class="text-forest mb-2">{content.accommodations[0].title}</h2>
          <p class="text-green font-semibold text-sm mb-4">{content.accommodations[0].subtitle}</p>
          <p class="text-gray-600 leading-relaxed mb-6">{content.accommodations[0].description}</p>

          <div class="flex flex-wrap gap-2 mb-6">
            {content.accommodations[0].features.map((f) => (
              <span class="text-xs px-3 py-1.5 rounded-full bg-moss/50 text-forest font-medium">{f}</span>
            ))}
          </div>

          <div class="bg-white rounded-xl p-5 border border-gray-100 mb-6">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Arrivée</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[0].checkin}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Départ</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[0].checkout}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Capacité</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[0].capacity}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Ouverture</p>
                <p class="text-forest font-semibold text-sm">{content.openingDates.emplacements.start} — {content.openingDates.emplacements.end}</p>
              </div>
            </div>
          </div>

          <a href={url('/contact')} class="btn btn-primary">
            Réserver un emplacement
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CHALETS -->
  <section id="chalets" class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 reveal reveal-delay-2">
          <span class="badge mb-4">Chalets</span>
          <h2 class="text-forest mb-2">{content.accommodations[1].title}</h2>
          <p class="text-green font-semibold text-sm mb-4">{content.accommodations[1].subtitle}</p>
          <p class="text-gray-600 leading-relaxed mb-6">{content.accommodations[1].description}</p>

          <div class="flex flex-wrap gap-2 mb-6">
            {content.accommodations[1].features.map((f) => (
              <span class="text-xs px-3 py-1.5 rounded-full bg-moss/50 text-forest font-medium">{f}</span>
            ))}
          </div>

          <div class="bg-white rounded-xl p-5 border border-gray-100 mb-6">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Arrivée</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[1].checkin}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Départ</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[1].checkout}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Capacité</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[1].capacity}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Ouverture</p>
                <p class="text-forest font-semibold text-sm">{content.openingDates.chalets}</p>
              </div>
            </div>
          </div>

          <a href={url('/contact')} class="btn btn-primary">
            Réserver un chalet
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="order-1 lg:order-2 reveal">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img
              src={url(content.accommodations[1].image)}
              alt={content.accommodations[1].imageAlt}
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
            <span class="absolute top-4 left-4 badge bg-white/90 text-forest text-xs">{content.accommodations[1].count} chalets — 35 m²</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TENTES BIVOUAC -->
  <section id="bivouac" class="py-16 lg:py-24 bg-cream-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img
              src={url(content.accommodations[2].image)}
              alt={content.accommodations[2].imageAlt}
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
            <span class="absolute top-4 left-4 badge bg-white/90 text-forest text-xs">{content.accommodations[2].count} tentes</span>
          </div>
        </div>
        <div class="reveal reveal-delay-2">
          <span class="badge mb-4">Tentes Bivouac</span>
          <h2 class="text-forest mb-2">{content.accommodations[2].title}</h2>
          <p class="text-green font-semibold text-sm mb-4">{content.accommodations[2].subtitle}</p>
          <p class="text-gray-600 leading-relaxed mb-6">{content.accommodations[2].description}</p>

          <div class="flex flex-wrap gap-2 mb-6">
            {content.accommodations[2].features.map((f) => (
              <span class="text-xs px-3 py-1.5 rounded-full bg-moss/50 text-forest font-medium">{f}</span>
            ))}
          </div>

          <div class="bg-white rounded-xl p-5 border border-gray-100 mb-6">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Capacité</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[2].capacity}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Ouverture</p>
                <p class="text-forest font-semibold text-sm">{content.openingDates.emplacements.start} — {content.openingDates.emplacements.end}</p>
              </div>
            </div>
          </div>

          <a href={url('/contact')} class="btn btn-primary">
            Réserver une tente bivouac
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAISON ÉCLUSIÈRE -->
  <section id="maison-eclusiere" class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 reveal reveal-delay-2">
          <span class="badge mb-4">Maison Éclusière</span>
          <h2 class="text-forest mb-2">{content.accommodations[3].title}</h2>
          <p class="text-green font-semibold text-sm mb-4">{content.accommodations[3].subtitle}</p>
          <p class="text-gray-600 leading-relaxed mb-6">{content.accommodations[3].description}</p>

          <div class="flex flex-wrap gap-2 mb-6">
            {content.accommodations[3].features.map((f) => (
              <span class="text-xs px-3 py-1.5 rounded-full bg-moss/50 text-forest font-medium">{f}</span>
            ))}
          </div>

          <div class="bg-white rounded-xl p-5 border border-gray-100 mb-6">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Capacité</p>
                <p class="text-forest font-semibold text-sm">{content.accommodations[3].capacity}</p>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Ouverture</p>
                <p class="text-forest font-semibold text-sm">{content.openingDates.maisonEclusiere}</p>
              </div>
            </div>
          </div>

          <a href={url('/contact')} class="btn btn-primary">
            Réserver la maison éclusière
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="order-1 lg:order-2 reveal">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img
              src={url(content.accommodations[3].image)}
              alt={content.accommodations[3].imageAlt}
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
            <span class="absolute top-4 left-4 badge bg-white/90 text-forest text-xs">Gîte de caractère</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Trouvez l'hébergement idéal"
    subtitle="Réservez dès maintenant votre emplacement, chalet, tente bivouac ou la maison éclusière."
    secondaryText="Voir les tarifs"
    secondaryUrl="/tarifs"
  />
</BaseLayout>
