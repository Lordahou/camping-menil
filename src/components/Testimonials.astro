---
import content from '../data/content.json';
---

<section class="py-20 lg:py-28 bg-forest relative overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" viewBox="0 0 800 400" fill="none">
      <path d="M0 200s100-50 200-50 200 100 400 50 200-100 200-100" stroke="currentColor" stroke-width="1" class="text-sage"/>
      <path d="M0 250s100-50 200-50 200 100 400 50 200-100 200-100" stroke="currentColor" stroke-width="1" class="text-sage" opacity="0.5"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-12 lg:mb-16">
      <span class="badge bg-white/15 text-white/90 mb-4">Avis de nos visiteurs</span>
      <h2 class="text-white mb-4">Ce qu'ils en disent</h2>
      <div class="flex items-center justify-center gap-3">
        <span class="text-sage text-3xl font-heading">9.6/10</span>
        <div class="text-left">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-sage" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></svg>
            ))}
          </div>
          <span class="text-white/50 text-xs">Excellent — Fairguest</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {content.testimonials.map((t, i) => (
        <div class={`reveal reveal-delay-${i + 1} bg-white/8 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/12 transition-all duration-300`}>
          <div class="flex gap-1 mb-4">
            {Array.from({length: t.rating}).map(() => (
              <svg class="w-4 h-4 text-sage" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></svg>
            ))}
          </div>
          <blockquote class="text-white/80 text-sm leading-relaxed mb-6 italic">
            "{t.text}"
          </blockquote>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-sage/20 flex items-center justify-center text-sage font-semibold text-sm">
              {t.author.charAt(0)}
            </div>
            <div>
              <p class="text-white font-medium text-sm">{t.author}</p>
              <p class="text-white/40 text-xs">{t.origin}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
