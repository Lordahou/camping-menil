---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  light?: boolean;
}

const { badge, title, subtitle, align = 'center', light = false } = Astro.props;
---

<div class={`mb-12 lg:mb-16 ${align === 'center' ? 'text-center max-w-3xl mx-auto' : ''}`}>
  {badge && (
    <span class={`badge mb-4 inline-flex ${light ? 'bg-white/15 text-white/90' : ''}`}>
      {badge}
    </span>
  )}
  <h2 class={`text-balance mb-4 ${light ? 'text-white' : 'text-forest'}`}>
    {title}
  </h2>
  {subtitle && (
    <p class={`text-lg leading-relaxed ${light ? 'text-white/70' : 'text-gray-500'}`}>
      {subtitle}
    </p>
  )}
</div>
