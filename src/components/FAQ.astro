---
import content from '../data/content.json';

interface Props {
  items?: Array<{ question: string; answer: string }>;
}

const { items = content.faq } = Astro.props;
---

<div class="space-y-3">
  {items.map((item, i) => (
    <details
      class="group bg-white rounded-xl border border-gray-200/60 overflow-hidden hover:border-sage/30 transition-colors duration-200"
    >
      <summary class="flex items-center justify-between cursor-pointer p-5 lg:p-6 text-forest font-semibold text-sm lg:text-base select-none list-none">
        <span class="pr-4">{item.question}</span>
        <svg class="w-5 h-5 text-sage flex-shrink-0 transition-transform duration-300 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </summary>
      <div class="px-5 lg:px-6 pb-5 lg:pb-6 text-gray-500 text-sm leading-relaxed -mt-1">
        {item.answer}
      </div>
    </details>
  ))}
</div>
